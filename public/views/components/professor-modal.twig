<!-- Modal: Adicionar / Editar Professor -->
<div class="modal fade" id="profModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="profModalTitle">Novo Professor</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="formProfessor" action="/admin/professores" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <input type="hidden" id="profId" name="id" value="">
          <input type="hidden" id="perfil" name="perfil" value="professor">
          <div class="mb-3">
            <label class="form-label">Nome Completo</label>
            <input type="text" id="profNome" name="nome_completo" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" id="profEmail" name="email" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Telefone</label>
            <input type="tel" id="profTelefone" name="telefone" class="form-control">
          </div>
           <div class="mb-3">
            <label class="form-label">Telefone Alternativo</label>
            <input type="tel" id="profTelefoneAlternativo" name="telefone_alternativo" class="form-control">
          </div>
          <div class="mb-3">            <label class="form-label">Endereço</label>
            <textarea id="profEndereco" name="endereco" class="form-control" rows="2" placeholder="Rua, número, bairro, cidade..."></textarea>
          </div>
          <div class="mb-3">            <label class="form-label">Senha Inicial</label>
            <input type="password" id="profSenha" name="senha" class="form-control" required placeholder="Digite uma senha inicial">
          </div>
          <div class="mb-3">
            <label class="form-label">Turmas e Disciplinas</label>
            <div class="border rounded p-3" style="height: 220px; overflow-y: auto;">
              {% for turma in turmas %}
              <div class="row g-3 align-items-center mb-3">
                <div class="col-auto">
                  <div class="form-check mb-0">
                    <input class="form-check-input turma-checkbox" type="checkbox" id="turma_{{ turma.id }}" value="{{ turma.id }}" name="turmas[]">
                    <label class="form-check-label" for="turma_{{ turma.id }}">{{ turma.codigo }}</label>
                  </div>
                </div>
                <div class="col">
                  <div class="small text-muted">Turno: {{ turma.turno }} — Classe: {{ turma.classe }} — Sala: {{ turma.sala }}</div>
                </div>
                <div class="col-md-4">
                  <select class="form-select turma-disciplina-select" data-turma-id="{{ turma.id }}" name="turma_disciplina_{{ turma.id }}[]" multiple disabled>
                    <option value="">Selecione disciplina(s)</option>
                    {% for disciplina in disciplinas %}
                      {% if turma.id_classe in disciplina.classe_ids|split(',') %}
                        <option value="{{ disciplina.id }}">{{ disciplina.disciplina }}</option>
                      {% endif %}
                    {% endfor %}
                  </select>
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
          <hr>
          <h6 class="mb-3">Habilitações Literárias</h6>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Grau Académico</label>
              <select class="form-select" id="profGrau" name="grau_academico" required>
                <option value="">Selecione...</option>
                <option value="Ensino Médio">Ensino Médio</option>
                <option value="Bacharelato">Bacharelato</option>
                <option value="Licenciatura">Licenciatura</option>
                <option value="Pós-Graduação">Pós-Graduação</option>
                <option value="Mestrado">Mestrado</option>
                <option value="Doutoramento">Doutoramento</option>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Área de Formação</label>
              <input type="text" id="profArea" class="form-control" name="area_formacao" placeholder="Ex: Informática, Matemática..." required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Instituição de Formação</label>
              <input type="text" id="profInstituicao" class="form-control" name="instituicao_formacao" placeholder="Ex: Universidade Agostinho Neto">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Ano de Conclusão</label>
              <input type="number" id="profAno" class="form-control" name="ano_conclusao" min="1980" max="2099" placeholder="Ex: 2022">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Nº do Certificado (Opcional)</label>
              <input type="text" class="form-control" name="numero_certificado">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Anexar Diploma/Certificado</label>
              <input type="file" class="form-control" name="arquivo_diploma" accept=".pdf,.jpg,.png">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const profModalEl = document.getElementById('profModal');
    const formProfessor = document.getElementById('formProfessor');
    
    console.log('Modal loaded, formProfessor:', formProfessor);

    // Listener para submit
    formProfessor.addEventListener('submit', function (e) {
      console.log('Form submit fired');
      // Deixar o submit natural acontecer - não fazer preventDefault
    });

    document.addEventListener('click', function (e) {
      const btn = e.target.closest('.btn-edit');
      if (!btn) return;

      const id = btn.getAttribute('data-id') || '';
      const nome = btn.getAttribute('data-nome') || '';
      const email = btn.getAttribute('data-email') || '';
      const telefone = btn.getAttribute('data-telefone') || '';
      const grau = btn.getAttribute('data-grau') || '';
      const area = btn.getAttribute('data-area') || '';
      const instituicao = btn.getAttribute('data-instituicao') || '';
      const ano = btn.getAttribute('data-ano') || '';
      const senha = btn.getAttribute('data-senha') || '';
      const turmas = (btn.getAttribute('data-turmas') || '').split(',').map(item => item.trim()).filter(Boolean);

      document.getElementById('profModalTitle').textContent = 'Editar Professor';
      document.getElementById('profId').value = id;
      document.getElementById('profNome').value = nome;
      document.getElementById('profEmail').value = email;
      document.getElementById('profTelefone').value = telefone;
      document.getElementById('profGrau').value = grau;
      document.getElementById('profArea').value = area;
      document.getElementById('profInstituicao').value = instituicao;
      document.getElementById('profAno').value = ano;
      document.getElementById('profSenha').value = senha;

      document.getElementById('profModalTitle').textContent = 'Editar Professor';
      document.getElementById('profNome').value = nome;
      document.getElementById('profEmail').value = email;
      document.getElementById('profTelefone').value = telefone;
      document.getElementById('profSenha').value = senha;

      const turmaMap = turmas.reduce((map, item) => {
        const parts = item.split(':').map(s => s.trim());
        const turmaId = parts[0];
        const disciplinaId = parts.length > 1 ? parts.slice(1).join(':') : null;
        if (!turmaId) return map;
        if (!map[turmaId]) {
          map[turmaId] = [];
        }
        if (disciplinaId) {
          map[turmaId].push(disciplinaId);
        }
        return map;
      }, {});

      document.querySelectorAll('.turma-checkbox').forEach(cb => {
        const turmaId = cb.value;
        const selectedDisciplinas = turmaMap[turmaId] || [];
        const select = document.querySelector(`.turma-disciplina-select[data-turma-id="${turmaId}"]`);
        cb.checked = selectedDisciplinas.length > 0;
        if (select) {
          select.disabled = !cb.checked;
          Array.from(select.options).forEach(option => {
            option.selected = selectedDisciplinas.includes(option.value);
          });
        }
      });
    });

    profModalEl.addEventListener('hidden.bs.modal', function () {
      document.getElementById('profModalTitle').textContent = 'Novo Professor';
      document.getElementById('formProfessor').reset();
      document.querySelectorAll('.turma-disciplina-select').forEach(select => {
        select.disabled = true;
      });
    });

    document.querySelectorAll('.turma-checkbox').forEach(cb => {
      cb.addEventListener('change', function () {
        const turmaId = this.value;
        const select = document.querySelector(`.turma-disciplina-select[data-turma-id="${turmaId}"]`);
        if (select) {
          select.disabled = !this.checked;
          if (!this.checked) {
            Array.from(select.options).forEach(option => option.selected = false);
          }
        }
      });
    });
  });
</script>
