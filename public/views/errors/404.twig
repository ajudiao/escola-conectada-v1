<!DOCTYPE html>
<html lang="pt-AO">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Página não encontrada</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background: #f8f9fa;
      color: #212529;
      font-family: Inter, system-ui, sans-serif;
    }
    .page-404 {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .page-404 .card {
      max-width: 540px;
      width: 100%;
      border: none;
      border-radius: 1rem;
      box-shadow: 0 0.75rem 1.5rem rgba(33, 37, 41, 0.08);
    }
  </style>
</head>
<body>
  <div class="page-404">
    <div class="card p-5 text-center">
      <div class="mb-4">
        <h1 class="display-4">404</h1>
        <p class="lead mb-0">Página não encontrada</p>
      </div>
      <p class="text-muted mb-4">{{ message ?? 'A URL solicitada não existe ou foi removida.' }}</p>
      <a href="{{ url('login') }}" class="btn btn-primary">Voltar ao login</a>
    </div>
  </div>
</body>
</html>
