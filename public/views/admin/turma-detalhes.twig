{% extends "layouts/admin.twig" %}
{% block content %}

    <main class="main-content">
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">☰</button>
          <h1 class="header-title">Detalhes da Turma</h1>
        </div>
        <div class="header-right">
          <div class="header-user"><div class="header-user-avatar">AD</div><div class="header-user-info"><span class="header-user-name">Administrador</span><span class="header-user-role">Administração</span></div></div>
        </div>
      </header>

      <div class="page-content">
        <a href="turmas.html" class="btn-back btn btn-outline-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Voltar
        </a>

        <!-- Header Section -->
        <div class="detail-header">
          <h1 class="detail-title">6A</h1>
        </div>

        <!-- Informações da Turma -->
        <h2 class="section-header">Informações da Turma</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Código da Turma</span>
            <div class="info-value">6A</div>
          </div>
          
          <div class="info-item">
            <span class="info-label">Classe</span>
            <div class="info-value">6ª</div>
          </div>
          <div class="info-item">
            <span class="info-label">Turno</span>
            <div class="info-value">Matutino</div>
          </div>
          <div class="info-item">
            <span class="info-label">Sala de Aula</span>
            <div class="info-value">5</div>
          </div>
          <div class="info-item">
            <span class="info-label">Data de Criação</span>
            <div class="info-value">10 de Janeiro de 2025</div>
          </div>
        </div>
        <!-- Alunos da Turma -->
        <h2 class="section-header">Alunos Inscritos (32 alunos)</h2>
        <div class="table-responsive-custom">
          <table class="table table-custom align-middle">
            <thead>
              <tr>
                <th>Nº</th>
                <th>Nome</th>
                <th>Nº Processo</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>1</td>
                <td><strong>Ana Pereira Silva</strong></td>
                <td>2026-001</td>
                <td><span class="badge bg-success">Ativo</span></td>
              </tr>
              <tr>
                <td>2</td>
                <td><strong>Bruno Mendes Costa</strong></td>
                <td>2026-002</td>
                <td><span class="badge bg-success">Ativo</span></td>
              </tr>
              <tr>
                <td>3</td>
                <td><strong>Cátia Silva Santos</strong></td>
                <td>2026-003</td>
                <td><span class="badge bg-success">Ativo</span></td>
              </tr>
              <tr>
                <td>4</td>
                <td><strong>Dário José Mateus</strong></td>
                <td>2026-004</td>
                <td><span class="badge bg-success">Ativo</span></td>
              </tr>
              <tr>
                <td>5</td>
                <td><strong>Elisa Maria da Cruz</strong></td>
                <td>2026-005</td>
                <td><span class="badge bg-success">Ativo</span></td>
              </tr>
              <tr>
                <td>6</td>
                <td><strong>Fernando Nunes da Silva</strong></td>
                <td>2026-006</td>
                <td><span class="badge bg-warning">Suspenso</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
          <button class="btn btn-primary">Editar Turma</button>
          <button class="btn btn-outline-secondary">Descarregar Pauta</button>
          <button class="btn btn-outline-danger">Eliminar Turma</button>
        </div>
      </div>

      <footer class="main-footer"><p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p></footer>
    </main>
 
{% endblock %}