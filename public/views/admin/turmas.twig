{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left"><button class="mobile-toggle">☰</button>
          <h1 class="header-title">Turmas</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Turmas</h2>
            <p class="page-subtitle">Turmas e respetivos detalhes</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#turmaModal">Nova Turma</button>
        </div>

        {% if flashMessages %}
          {% for message in flashMessages %}
            <div class="alert alert-{{ message.type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
              {{ message.message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endif %}

        <!-- Filters -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-4">
                <label class="form-label">Pesquisar</label>
                <input id="filterTurmaSearch" type="text" class="form-control" placeholder="Código, curso, professor...">
              </div>
              <div class="col-md-2">
                <label class="form-label">Classe</label>
                <select id="filterTurmaCiclo" class="form-control form-select">
                  <option value="">Todos</option>
                  <option>10ª</option>
                  <option>11ª</option>
                  <option>12ª</option>
                  <option>13ª</option>
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label">Sala</label>
                <input id="filterTurmaSala" type="text" class="form-control" placeholder="Ex: A101">
              </div>
              <div class="col-md-2">
                <label class="form-label">Ano Letivo</label>
                <select id="filterTurmaAno" class="form-control form-select">
                  <option value="2025/2026">2025/2026</option>
                  <option value="2024/2025">2024/2025</option>
                  <option value="2023/2024">2023/2024</option>
                  
                </select>
              </div>
              <div class="col-md-2">
                <button id="btnFilterTurma" class="btn btn-outline-primary w-100">Filtrar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Código</th>
                    <th>Classe</th>
                    <th>Turno</th>
                    <th>Sala</th>
                    <th>Ano Letivo</th>
                    <th>Diretor de Turma</th>
                    <th>Nº Alunos</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  {% if turmas is not empty %}
                    {% for turma in turmas %}
                      <tr>
                        <td>{{ turma.codigo }}</td>
                        <td><span class="badge bg-info">{{ turma.classe ?: '—' }}</span></td>
                        <td>{{ turma.turno }}</td>
                        <td>{{ turma.sala }}</td>
                        <td>{{ turma.ano_lectivo }}</td>
                        <td>—</td>
                        <td>{{ turma.quantidade_alunos }}</td>
                        <td>
                          <a href="/admin/turma/show/{{ turma.id }}" class="btn btn-sm btn-outline-info me-1">Ver</a>
                          <button class="btn btn-sm btn-outline-secondary me-1 btn-edit" data-bs-toggle="modal"
                            data-bs-target="#turmaModal" data-id="{{ turma.id }}" data-codigo="{{ turma.codigo }}"
                            data-classe="{{ turma.id_classe }}" data-turno="{{ turma.turno }}"
                            data-sala="{{ turma.sala }}" data-ano="{{ turma.ano_lectivo }}" data-num="{{ turma.quantidade_alunos }}">Editar</button>
                          <form action="/admin/turma/{{ turma.id }}/delete" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                          </form>
                        </td>
                      </tr>
                    {% endfor %}
                  {% else %}
                    <tr>
                      <td colspan="8" class="text-center text-muted">Nenhuma turma cadastrada.</td>
                    </tr>
                  {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        {% include 'components/turma-modal.twig' %}
      </div>
      <footer class="main-footer">
        <p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p>
      </footer>
    </main>
  </div>
 
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const turmaModalEl = document.getElementById('turmaModal');
      const turmaForm = document.getElementById('formTurma');
      const turmaModalTitle = document.getElementById('turmaModalTitle');
      const turmaIdInput = document.getElementById('turmaId');
      const turmaCodigo = document.getElementById('turmaCodigo');
      const turmaClasse = document.getElementById('turmaClasse');
      const turmaTurno = document.getElementById('turmaTurno');
      const turmaSala = document.getElementById('turmaSala');
      const turmaAno = document.getElementById('turmaAno');
      const turmaNum = document.getElementById('turmaNum');

      document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-edit');
        if (!btn) return;

        const id = btn.getAttribute('data-id') || '';
        const codigo = btn.getAttribute('data-codigo') || '';
        const classe = btn.getAttribute('data-classe') || '';
        const turno = btn.getAttribute('data-turno') || '';
        const sala = btn.getAttribute('data-sala') || '';
        const ano = btn.getAttribute('data-ano') || '';
        const num = btn.getAttribute('data-num') || '';

        turmaModalTitle.textContent = 'Editar Turma';
        turmaIdInput.value = id;
        turmaCodigo.value = codigo;
        turmaClasse.value = classe;
        turmaTurno.value = turno;
        turmaSala.value = sala;
        turmaAno.value = ano;
        turmaNum.value = num;
        turmaForm.action = '/admin/turma/' + id;
      });

      turmaModalEl.addEventListener('hidden.bs.modal', function () {
        turmaModalTitle.textContent = 'Nova Turma';
        turmaForm.reset();
        turmaForm.action = '/admin/turma';
        turmaIdInput.value = '';
      });

      document.getElementById('btnFilterTurma').addEventListener('click', function() {
        const q = document.getElementById('filterTurmaSearch').value.trim().toLowerCase();
        const classe = document.getElementById('filterTurmaCiclo').value;
        const sala = document.getElementById('filterTurmaSala').value.trim().toLowerCase();
        const ano = document.getElementById('filterTurmaAno').value;

        document.querySelectorAll('table tbody tr').forEach(tr => {
          const cols = tr.children;
          const codigo = (cols[0]?.textContent||'').toLowerCase();
          const classeTd = (cols[1]?.textContent||'').trim();
          const turnoTd = (cols[2]?.textContent||'').toLowerCase();
          const salaTd = (cols[3]?.textContent||'').toLowerCase();
          const anoTd = (cols[4]?.textContent||'').trim();

          let matches = true;
          if (q) matches = matches && (codigo.includes(q) || classeTd.toLowerCase().includes(q) || turnoTd.includes(q));
          if (classe) matches = matches && (classeTd === classe);
          if (sala) matches = matches && salaTd.includes(sala);
          if (ano) matches = matches && (anoTd === ano);

          tr.style.display = matches ? '' : 'none';
        });
      });
    });
  </script>

{% endblock %}