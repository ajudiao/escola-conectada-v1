{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">☰</button>
          <h1 class="header-title">Professores</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <!-- Flash Messages -->
        {% if flashMessages %}
          {% for message in flashMessages %}
            <div class="alert alert-{{ message.type == 'success' ? 'success' : (message.type == 'warning' ? 'warning' : 'danger') }} alert-dismissible fade show" role="alert">
              {{ message.message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endif %}

        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Professores</h2>
            <p class="page-subtitle">Lista de docentes registados no sistema</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#profModal">Novo Professor</button>
        </div>

        <!-- Filters -->
        <div class="card mb-4">
          <div class="card-body">
            <form method="GET" action="/admin/professores" class="row g-3 align-items-end mb-4">
              <div class="col-md-4">
                <label class="form-label">Pesquisar</label>
                <input type="text" class="form-control" name="search" placeholder="Nome, email ou telefone..." value="{{ search is not null ? search : '' }}">
              </div>
              <div class="col-md-3">
                <label class="form-label">Disciplina</label>
                <select class="form-control form-select" name="disciplina">
                  <option value="">Todas</option>
                  {% if disciplinas %}
                    {% for disciplina in disciplinas %}
                      <option value="{{ disciplina.id }}" {% if disciplina_id == disciplina.id %}selected{% endif %}>{{ disciplina.disciplina }}</option>
                    {% endfor %}
                  {% endif %}
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">Turma</label>
                <select class="form-control form-select" name="turma">
                  <option value="">Todas</option>
                  {% if turmas %}
                    {% for turma in turmas %}
                      <option value="{{ turma.id }}" {% if turma_id == turma.id %}selected{% endif %}>{{ turma.codigo }} - {{ turma.classe }}</option>
                    {% endfor %}
                  {% endif %}
                </select>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
              </div>
              {% if search or disciplina_id or turma_id %}
                <div class="col-md-12">
                  <a href="/admin/professores" class="btn btn-sm btn-outline-secondary">Limpar Filtros</a>
                </div>
              {% endif %}
            </form>

        <!-- Professores Table -->
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Telefone</th>
                    <th>Grau Académico</th>
                    <th>Área de Formação</th>
                    <th>Instituição</th>
                    <th>Ano Conclusão</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  {% if professores|length > 0 %}
                    {% for professor in professores %}
                      <tr>
                        <td>{{ professor.nome_completo }}</td>
                        <td>{{ professor.email }}</td>
                        <td>{{ professor.telefone }}</td>
                        <td>{{ professor.grau_academico }}</td>
                        <td>{{ professor.area_formacao }}</td>
                        <td>{{ professor.instituicao_formacao }}</td>
                        <td>{{ professor.ano_conclusao }}</td>
                        <td>
                          <button type="button" class="btn btn-sm btn-outline-info me-1" title="Ver Detalhes" 
                            onclick="verProfessor({{ professor.id }})">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                              <circle cx="12" cy="12" r="3"/>
                            </svg>
                          </button>
                          <button type="button" class="btn btn-sm btn-outline-secondary me-1" title="Editar" 
                            data-bs-toggle="modal" data-bs-target="#profModal" 
                            data-id="{{ professor.id }}" 
                            data-nome="{{ professor.nome_completo }}" 
                            data-email="{{ professor.email }}"
                            data-telefone="{{ professor.telefone }}" 
                            data-grau="{{ professor.grau_academico }}" 
                            data-area="{{ professor.area_formacao }}"
                            data-instituicao="{{ professor.instituicao_formacao }}" 
                            data-ano="{{ professor.ano_conclusao }}" 
                            data-turmas="{{ professor.turmas_disciplinas }}">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                          </button>
                          <button type="button" class="btn btn-sm btn-outline-danger" title="Eliminar" 
                            onclick="confirmarDelecao({{ professor.id }}, '{{ professor.nome_completo | escape('js') }}')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="3 6 5 6 21 6"/>
                              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                            </svg>
                          </button>
                        </td>
                      </tr>
                    {% endfor %}
                  {% else %}
                    <tr>
                      <td colspan="8" class="text-center py-5">
                        <div class="alert alert-info d-inline-block" role="alert">
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" 
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" 
                            class="me-2" style="display: inline; vertical-align: text-bottom;">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                          </svg>
                          Nenhum professor registado ainda. Clique em "Novo Professor" para adicionar um.
                        </div>
                      </td>
                    </tr>
                  {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        {% include 'components/professor-modal.twig' with {'turmas': turmas, 'disciplinas': disciplinas} %}
      </div>

      <!-- Footer -->
      <footer class="main-footer">
        <p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p>
      </footer>
    </main>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Open edit modal and populate
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-edit');
        if (!btn) return;
        const id = btn.getAttribute('data-id') || '';
        const nome = btn.getAttribute('data-nome') || '';
        const email = btn.getAttribute('data-email') || '';
        const telefone = btn.getAttribute('data-telefone') || '';
        const grau = btn.getAttribute('data-grau') || '';
        const area = btn.getAttribute('data-area') || '';
        const instituicao = btn.getAttribute('data-instituicao') || '';
        const ano = btn.getAttribute('data-ano') || '';
        const senha = btn.getAttribute('data-senha') || '';
        const turmas = (btn.getAttribute('data-turmas') || '').split(',').map(item => item.trim()).filter(Boolean);

        document.getElementById('profModalTitle').textContent = 'Editar Professor';
        document.getElementById('profId').value = id;
        document.getElementById('profNome').value = nome;
        document.getElementById('profEmail').value = email;
        document.getElementById('profTelefone').value = telefone;
        document.getElementById('profGrau').value = grau;
        document.getElementById('profArea').value = area;
        document.getElementById('profInstituicao').value = instituicao;
        document.getElementById('profAno').value = ano;
        document.getElementById('profSenha').value = senha;

        const turmaMap = turmas.reduce((map, item) => {
          const parts = item.split(':').map(s => s.trim());
          const turmaId = parts[0];
          const disciplinaId = parts.length > 1 ? parts.slice(1).join(':') : null;
          if (!turmaId) return map;
          if (!map[turmaId]) {
            map[turmaId] = [];
          }
          if (disciplinaId) {
            map[turmaId].push(disciplinaId);
          }
          return map;
        }, {});

        document.querySelectorAll('.turma-checkbox').forEach(cb => {
          const turmaId = cb.value;
          const selectedDisciplinas = turmaMap[turmaId] || [];
          const select = document.querySelector(`.turma-disciplina-select[data-turma-id="${turmaId}"]`);
          cb.checked = selectedDisciplinas.length > 0;
          if (select) {
            select.disabled = !cb.checked;
            Array.from(select.options).forEach(option => {
              option.selected = selectedDisciplinas.includes(option.value);
            });
          }
        });

        document.querySelectorAll('.turma-disciplina-select').forEach(select => {
          const turmaId = select.dataset.turmaId;
          select.disabled = !document.querySelector(`.turma-checkbox[value="${turmaId}"]`).checked;
        });
      });

      const profModalEl = document.getElementById('profModal');
      profModalEl.addEventListener('hidden.bs.modal', function () {
        document.getElementById('profModalTitle').textContent = 'Novo Professor';
        document.getElementById('formProfessor').reset();
        document.querySelectorAll('.turma-disciplina-select').forEach(select => {
          select.disabled = true;
        });
      });

      document.querySelectorAll('.turma-checkbox').forEach(cb => {
        cb.addEventListener('change', function () {
          const turmaId = this.value;
          const select = document.querySelector(`.turma-disciplina-select[data-turma-id="${turmaId}"]`);
          if (select) {
            select.disabled = !this.checked;
            if (!this.checked) {
              Array.from(select.options).forEach(option => option.selected = false);
            }
          }
        });
      });

      // Prevent default submit (user will hook to backend later)
      // REMOVIDO - conflito com modal componente
      // document.getElementById('formProfessor').addEventListener('submit', function (e) {
      //   e.preventDefault();
      //   ...
      // });

      // Filter professors by search, disciplina and turma
      document.getElementById('btnFilterProf').addEventListener('click', function () {
        const q = document.getElementById('filterProfSearch').value.trim().toLowerCase();
        const disc = document.getElementById('filterProfDisc').value;
        const turma = document.getElementById('filterProfTurma').value;

        document.querySelectorAll('table tbody tr').forEach(tr => {
          const name = (tr.children[0] && tr.children[0].textContent || '').toLowerCase();
          const email = (tr.children[1] && tr.children[1].textContent || '').toLowerCase();
          const disciplina = (tr.children[3] && tr.children[3].textContent || '').trim();
          const turmasAttr = (tr.getAttribute('data-turmas') || '').split(',').map(s => s.trim()).filter(Boolean);

          let matches = true;
          if (q) matches = matches && (name.includes(q) || email.includes(q) || disciplina.toLowerCase().includes(q));
          if (disc) matches = matches && (disciplina === disc);
          if (turma) matches = matches && turmasAttr.includes(turma);

          tr.style.display = matches ? '' : 'none';
        });
      });
    });

    // Função para confirmar deleção
    function confirmarDelecao(professorId, nomeProfessor) {
      if (confirm(`Tem certeza que deseja eliminar o professor "${nomeProfessor}"? Esta ação não pode ser desfeita.`)) {
        // Criar formulário dinamicamente para submeter
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/professores/${professorId}/delete`;
        
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = '_method';
        input.value = 'DELETE';
        
        form.appendChild(input);
        document.body.appendChild(form);
        form.submit();
      }
    }

    // Função para ver detalhes do professor
    function verProfessor(professorId) {
      window.location.href = `/admin/professores/show/${professorId}`;
    }
  </script>

{%endblock%}