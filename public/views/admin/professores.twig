{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">☰</button>
          <h1 class="header-title">Professores</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Professores</h2>
            <p class="page-subtitle">Lista de docentes registados no sistema</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#profModal">Novo Professor</button>
        </div>

        <!-- Filters -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-5">
                <label class="form-label">Pesquisar</label>
                <input type="text" id="filterProfSearch" class="form-control" placeholder="Nome, email...">
              </div>
              <div class="col-md-3">
                <label class="form-label">Disciplina</label>
                <select id="filterProfDisc" class="form-control form-select">
                  <option value="">Todas</option>
                  <option>Matemática</option>
                  <option>Física</option>
                  <option>Biologia</option>
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label">Turma</label>
                <select id="filterProfTurma" class="form-control form-select">
                  <option value="">Todas</option>
                  <option value="1"><span>4A</span> — Manhã — A101</option>
                  <option value="2"><span>4B</span> — Tarde — A102</option>
                  <option value="3"><span>4C</span> — Noite — A103</option>
                </select>
              </div>
              <div class="col-md-2">
                <button id="btnFilterProf" class="btn btn-outline-primary w-100">Filtrar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Telefone</th>
                    <th>Grau Académico</th>
                    <th>Área de Formação</th>
                    <th>Instituição</th>
                    <th>Ano Conclusão</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  {% if professores|length > 0 %}
                    {% for professor in professores %}
                      <tr data-professor-id="{{ professor.id }}">
                        <td>{{ professor.nome_completo }}</td>
                        <td>{{ professor.email }}</td>
                        <td>{{ professor.telefone }}</td>
                        <td>{{ professor.grau_academico }}</td>
                        <td>{{ professor.area_formacao }}</td>
                        <td>{{ professor.instituicao_formacao }}</td>
                        <td>{{ professor.ano_conclusao }}</td>
                        <td>
                          <a href="/admin/professor/{{ professor.id }}" class="btn btn-sm btn-outline-info me-1">Ver</a>
                          <button class="btn btn-sm btn-outline-secondary me-1 btn-edit" data-bs-toggle="modal"
                            data-bs-target="#profModal" data-id="{{ professor.id }}" data-nome="{{ professor.nome_completo }}" data-email="{{ professor.email }}"
                            data-telefone="{{ professor.telefone }}" data-grau="{{ professor.grau_academico }}" data-area="{{ professor.area_formacao }}"
                            data-instituicao="{{ professor.instituicao_formacao }}" data-ano="{{ professor.ano_conclusao }}" data-turmas="{{ professor.turmas_disciplinas }}">Editar</button>
                          <button class="btn btn-sm btn-outline-danger btn-delete" data-id="{{ professor.id }}">Eliminar</button>
                        </td>
                      </tr>
                    {% endfor %}
                  {% else %}
                    <tr>
                      <td colspan="8" class="text-center text-muted py-4">Nenhum professor registado</td>
                    </tr>
                  {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        {% include 'components/professor-modal.twig' with {'turmas': turmas, 'disciplinas': disciplinas} %}
      </div>


    </main>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Open edit modal and populate
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-edit');
        if (!btn) return;
        const nome = btn.getAttribute('data-nome') || '';
        const email = btn.getAttribute('data-email') || '';
        const telefone = btn.getAttribute('data-telefone') || '';
        const senha = btn.getAttribute('data-senha') || '';
        const turmas = (btn.getAttribute('data-turmas') || '').split(',').map(item => item.trim()).filter(Boolean);

        document.getElementById('profModalTitle').textContent = 'Editar Professor';
        document.getElementById('profNome').value = nome;
        document.getElementById('profEmail').value = email;
        document.getElementById('profTelefone').value = telefone;
        document.getElementById('profSenha').value = senha;

        const turmaMap = turmas.reduce((map, item) => {
          const parts = item.split(':').map(s => s.trim());
          const id = parts[0];
          const disciplina = parts.length > 1 ? parts.slice(1).join(':') : null;
          if (id) map[id] = disciplina;
          return map;
        }, {});

        document.querySelectorAll('.turma-checkbox').forEach(cb => {
          const turmaId = cb.value;
          const selectedDisciplina = turmaMap[turmaId];
          const select = document.querySelector(`.turma-disciplina-select[data-turma-id="${turmaId}"]`);
          cb.checked = selectedDisciplina !== undefined;
          if (select) {
            select.disabled = !cb.checked;
            select.value = selectedDisciplina || '';
          }
        });

        // enable selects for any selected turma and clear unselected ones
        document.querySelectorAll('.turma-disciplina-select').forEach(select => {
          const turmaId = select.dataset.turmaId;
          select.disabled = !document.querySelector(`.turma-checkbox[value="${turmaId}"]`).checked;
        });
      });

      const profModalEl = document.getElementById('profModal');
      profModalEl.addEventListener('hidden.bs.modal', function () {
        document.getElementById('profModalTitle').textContent = 'Novo Professor';
        document.getElementById('formProfessor').reset();
        document.querySelectorAll('.turma-disciplina-select').forEach(select => {
          select.disabled = true;
        });
      });

      document.querySelectorAll('.turma-checkbox').forEach(cb => {
        cb.addEventListener('change', function () {
          const turmaId = this.value;
          const select = document.querySelector(`.turma-disciplina-select[data-turma-id="${turmaId}"]`);
          if (select) {
            select.disabled = !this.checked;
            if (!this.checked) select.value = '';
          }
        });
      });

      // Prevent default submit (user will hook to backend later)
      // REMOVIDO - conflito com modal componente
      // document.getElementById('formProfessor').addEventListener('submit', function (e) {
      //   e.preventDefault();
      //   ...
      // });

      // Filter professors by search, disciplina and turma
      document.getElementById('btnFilterProf').addEventListener('click', function () {
        const q = document.getElementById('filterProfSearch').value.trim().toLowerCase();
        const disc = document.getElementById('filterProfDisc').value;
        const turma = document.getElementById('filterProfTurma').value;

        document.querySelectorAll('table tbody tr').forEach(tr => {
          const name = (tr.children[0] && tr.children[0].textContent || '').toLowerCase();
          const email = (tr.children[1] && tr.children[1].textContent || '').toLowerCase();
          const disciplina = (tr.children[3] && tr.children[3].textContent || '').trim();
          const turmasAttr = (tr.getAttribute('data-turmas') || '').split(',').map(s => s.trim()).filter(Boolean);

          let matches = true;
          if (q) matches = matches && (name.includes(q) || email.includes(q) || disciplina.toLowerCase().includes(q));
          if (disc) matches = matches && (disciplina === disc);
          if (turma) matches = matches && turmasAttr.includes(turma);

          tr.style.display = matches ? '' : 'none';
        });
      });
    });
  </script>

{%endblock%}