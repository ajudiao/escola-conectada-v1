{% extends "layouts/admin.twig" %}
{% block content %}
    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <h1 class="header-title">Meu Perfil</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info">
              <span class="header-user-name">Administrador</span>
              <span class="header-user-role">Administração</span>
            </div>
          </div>
        </div>
      </header>
      
      <!-- Page Content -->
      <div class="page-content">
        <div class="row g-4">
          <!-- Profile Card -->
          <div class="col-lg-4">
            <div class="profile-card">
              <div class="profile-header">
                <div class="profile-avatar">AD</div>
                <h3 class="profile-name">Administrador Geral</h3>
                <p class="profile-role mb-0">Administração do Sistema</p>
              </div>
              <div class="profile-body">
                <div class="profile-info-group">
                  <div class="profile-info-title">Informações de Conta</div>
                  <div class="profile-info-item">
                    <span class="profile-info-label">Utilizador:</span>
                    <span class="profile-info-value">admin</span>
                  </div>
                  <div class="profile-info-item">
                    <span class="profile-info-label">Último acesso:</span>
                    <span class="profile-info-value">Hoje, 08:45</span>
                  </div>
                  <div class="profile-info-item">
                    <span class="profile-info-label">Estado:</span>
                    <span class="profile-info-value"><span class="badge badge-success">Activo</span></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Profile Settings -->
          <div class="col-lg-8">
            <div class="card">
              <div class="card-header">
                <h5 class="card-title mb-0">Configurações da Conta</h5>
              </div>
              <div class="card-body">
                <form id="formPerfil">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label">Nome Completo</label>
                      <input type="text" class="form-control" value="{{ userName }}" readonly>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Email</label>
                      <input type="email" class="form-control" value="{{ email }}">
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Telefone</label>
                      <input type="tel" class="form-control" value="+244 923 000 001">
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Cargo</label>
                      <input type="text" class="form-control" value="Administrador do Sistema" readonly>
                    </div>
                  </div>
                  
                  <hr class="my-4">
                  
                  <h6 class="mb-3">Alterar Palavra-passe</h6>
                  <div class="row g-3">
                    <div class="col-md-4">
                      <label class="form-label">Palavra-passe Actual</label>
                      <input type="password" class="form-control" placeholder="Digite a actual">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label">Nova Palavra-passe</label>
                      <input type="password" class="form-control" placeholder="Digite a nova">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label">Confirmar Nova</label>
                      <input type="password" class="form-control" value="" placeholder="Confirme a nova">
                    </div>
                  </div>
                  
                  <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Guardar Alterações</button>
                  </div>
                </form>
              </div>
            </div>
            
            <!-- System Info -->
            <div class="card mt-4">
              <div class="card-header">
                <h5 class="card-title mb-0">Informações do Sistema</h5>
              </div>
              <div class="card-body">
                <div class="row g-3">
                  <div class="col-md-6">
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">Versão do Sistema:</span>
                      <span class="fw-medium">1.0.0</span>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">Ano Lectivo:</span>
                      <span class="fw-medium">2026/2025</span>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">Escola:</span>
                      <span class="fw-medium">Instituto Políteco 17 de Setembro</span>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">Província:</span>
                      <span class="fw-medium">Luanda</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Footer -->
      {% include 'components/footer.twig' %}
    </main>
  </div>
  
  
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.getElementById('formPerfil').addEventListener('submit', function(e) {
        e.preventDefault();
        Utils.mostrarNotificacao('Alterações guardadas com sucesso!', 'success');
      });
    });
  </script>
{% endblock %}