{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">☰</button>
          <h1 class="header-title">Detalhes do Aluno</h1>
        </div>
        <div class="header-right">
          <div class="header-user"><div class="header-user-avatar">AD</div><div class="header-user-info"><span class="header-user-name">Administrador</span><span class="header-user-role">Administração</span></div></div>
        </div>
      </header>

      <div class="page-content">
        <a href="alunos.html" class="btn-back btn btn-outline-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Voltar
        </a>

        <!-- Header Section -->
        <div class="detail-header">
          <h1 class="detail-title">Ana Pereira Silva</h1>
          <p class="detail-subtitle">Aluno • 4A <span class="text-green"> (Ativo) </span></p>
        </div>

        <!-- Informações Pessoais -->
        <h2 class="section-header">Informações Pessoais</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Nº de Processo</span>
            <div class="info-value">2026-001</div>
          </div>
          <div class="info-item">
            <span class="info-label">Email</span>
            <div class="info-value">ana.pereira@aluno.med.ao</div>
          </div>
          <div class="info-item">
            <span class="info-label">Telefone</span>
            <div class="info-value">+244 922 000 004</div>
          </div>
          <div class="info-item">
            <span class="info-label">Data de Nascimento</span>
            <div class="info-value">03 de Março de 2008</div>
          </div>
          <div class="info-item">
            <span class="info-label">Número de ID</span>
            <div class="info-value">000456789012</div>
          </div>
          <div class="info-item">
            <span class="info-label">Endereço</span>
            <div class="info-value">Av. João Paulo II, nº 123, Luanda</div>
          </div>
        </div>

        <!-- Informações Académicas -->
        <h2 class="section-header">Informações Académicas</h2>
        <div class="info-grid">
          
          <div class="info-item">
            <span class="info-label">Classe</span>
            <div class="info-value">4ª Classe</div>
          </div>
          <div class="info-item">
            <span class="info-label">Turma</span>
            <div class="info-value">4A</div>
          </div>
          <div class="info-item">
            <span class="info-label">Data de Matrícula</span>
            <div class="info-value">05 de Março de 2025</div>
          </div>
        </div>

        <!-- Encarregado de Educação -->
        <h2 class="section-header">Encarregado de Educação</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Nome</span>
            <div class="info-value">Maria José Santos</div>
          </div>
          <div class="info-item">
            <span class="info-label">Telefone</span>
            <div class="info-value">+244 912 345 678</div>
          </div>
          <div class="info-item">
            <span class="info-label">Email</span>
            <div class="info-value">maria.santos@email.ao</div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
          <button class="btn btn-primary">Editar Aluno</button>
          <button class="btn btn-outline-secondary">Descarregar Boletim</button>
          <button class="btn btn-outline-danger">Eliminar Aluno</button>
        </div>
      </div>

      <footer class="main-footer"><p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p></footer>
    </main>
  
{% endblock %}