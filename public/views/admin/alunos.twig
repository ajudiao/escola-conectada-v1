{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left"><button class="mobile-toggle">☰</button>
          <h1 class="header-title">Alunos</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <!-- Flash Messages -->
        {% if flashMessages %}
          {% for message in flashMessages %}
            <div class="alert alert-{{ message.type == 'error' ? 'danger' : message.type }} alert-dismissible fade show" role="alert">
              {{ message.message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endif %}

        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Alunos</h2>
            <p class="page-subtitle">Lista de alunos inscritos</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#alunoModal">Novo Aluno</button>
        </div>

        <!-- Filters -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-5">
                <label class="form-label">Pesquisar</label>
                <input id="filterAlunoSearch" type="text" class="form-control" placeholder="Nome ou nº processo">
              </div>
              <div class="col-md-3">
                <label class="form-label">Turma</label>
                <select id="filterAlunoTurma" class="form-control form-select">
                  <option value="">Todas</option>
                  {% for turma in turmas %}
                  <option value="{{ turma.id }}">{{ turma.codigo }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label">Sexo</label>
                <select id="filterAlunoSexo" class="form-control form-select">
                  <option value="">Todos</option>
                  <option value="M">Masculino</option>
                  <option value="F">Feminino</option>
                </select>
              </div>
              <div class="col-md-2">
                <div class="d-flex gap-2">
                  <button id="btnFilterAluno" class="btn btn-outline-primary flex-fill">Filtrar</button>
                  <button id="btnClearFilters" class="btn btn-outline-secondary">Limpar</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Nº Processo</th>
                    <th>Nome</th>
                    <th>Turma</th>
                    <th>Encarregado</th>
                    <th>Contacto</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  {% for aluno in alunos %}
                  <tr>
                    <td>{{ aluno.n_processo }}</td>
                    <td>{{ aluno.nome_completo }}</td>
                    <td>
                      {% for turma in turmas %}
                        {% if turma.id == aluno.id_turma %}
                          {{ turma.codigo }}
                        {% endif %}
                      {% endfor %}
                    </td>
                    <td>{{ aluno.encarregado_nome }}</td>
                    <td>{{ aluno.telefone }}</td>
                    <td>
                      <a href="/admin/aluno/show/{{ aluno.id }}" class="btn btn-sm btn-outline-info me-1">Ver</a>
                      <button class="btn btn-sm btn-outline-secondary me-1 btn-edit" data-bs-toggle="modal"
                        data-bs-target="#alunoModal"
                        data-id="{{ aluno.id }}"
                        data-nome="{{ aluno.nome_completo }}"
                        data-processo="{{ aluno.n_processo }}"
                        data-nascimento="{{ aluno.data_nascimento }}"
                        data-sexo="{{ aluno.sexo }}"
                        data-nacionalidade="{{ aluno.nacionalidade }}"
                        data-email="{{ aluno.email }}"
                        data-telefone="{{ aluno.telefone }}"
                        data-turma="{{ aluno.id_turma }}"
                        data-encarregado="{{ aluno.id_encarregado }}">Editar</button>
                      <form method="POST" action="/admin/alunos/{{ aluno.id }}/delete" style="display: inline;">
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                          onclick="return confirm('Tem certeza que deseja eliminar este aluno?')">Eliminar</button>
                      </form>
                    </td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Include Modal Component -->
        {% include 'components/aluno-modal.twig' %}
      </div>
      
      {% include 'components/footer.twig' %}
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-edit');
        if (!btn) return;

        const id = btn.getAttribute('data-id') || '';
        const nome = btn.getAttribute('data-nome') || '';
        const processo = btn.getAttribute('data-processo') || '';
        const nascimento = btn.getAttribute('data-nascimento') || '';
        const sexo = btn.getAttribute('data-sexo') || '';
        const nacionalidade = btn.getAttribute('data-nacionalidade') || '';
        const email = btn.getAttribute('data-email') || '';
        const telefone = btn.getAttribute('data-telefone') || '';
        const turma = btn.getAttribute('data-turma') || '';
        const encarregado = btn.getAttribute('data-encarregado') || '';

        document.getElementById('alunoModalTitle').textContent = 'Editar Aluno';
        document.getElementById('alunoId').value = id;
        document.getElementById('alunoNome').value = nome;
        document.getElementById('alunoNProcesso').value = processo;
        document.getElementById('alunoDataNascimento').value = nascimento;
        document.getElementById('alunoSexo').value = sexo;
        document.getElementById('alunoNacionalidade').value = nacionalidade;
        document.getElementById('alunoEmail').value = email;
        document.getElementById('alunoTelefone').value = telefone;
        document.getElementById('alunoTurma').value = turma;
        document.getElementById('alunoEncarregado').value = encarregado;

        // Change form action for update
        document.getElementById('formAluno').action = '/admin/alunos/update/' + id;
      });

      const alunoModalEl = document.getElementById('alunoModal');
      alunoModalEl.addEventListener('hidden.bs.modal', function () {
        document.getElementById('alunoModalTitle').textContent = 'Novo Aluno';
        document.getElementById('formAluno').reset();
        document.getElementById('formAluno').action = '/admin/alunos';
        document.getElementById('alunoId').value = '';
      });

      // Botão Filtrar (aplica filtros de dropdown + mantém filtro de texto)
      document.getElementById('btnFilterAluno').addEventListener('click', function() {
        const searchValue = document.getElementById('filterAlunoSearch').value.trim().toLowerCase();
        const turmaValue = document.getElementById('filterAlunoTurma').value;
        const sexoValue = document.getElementById('filterAlunoSexo').value;

        document.querySelectorAll('table tbody tr').forEach(tr => {
          const cols = tr.children;
          if (cols.length < 5) return;

          const nProcesso = (cols[0]?.textContent || '').toLowerCase();
          const nome = (cols[1]?.textContent || '').toLowerCase();

          // Buscar dados nos data attributes do botão editar
          const btnEdit = tr.querySelector('.btn-edit');
          const sexo = btnEdit ? (btnEdit.getAttribute('data-sexo') || '').toLowerCase() : '';
          const turmaId = btnEdit ? btnEdit.getAttribute('data-turma') : '';

          let matches = true;

          // Filtro de pesquisa (sempre ativo - nome ou nº processo)
          if (searchValue) {
            matches = matches && (nProcesso.includes(searchValue) || nome.includes(searchValue));
          }

          // Filtro de turma
          if (turmaValue) {
            matches = matches && (turmaId === turmaValue);
          }

          // Filtro de sexo
          if (sexoValue) {
            matches = matches && (sexo === sexoValue.toLowerCase());
          }

          tr.style.display = matches ? '' : 'none';
        });
      });

      // Botão Limpar Filtros
      document.getElementById('btnClearFilters').addEventListener('click', function() {
        document.getElementById('filterAlunoSearch').value = '';
        document.getElementById('filterAlunoTurma').value = '';
        document.getElementById('filterAlunoSexo').value = '';
        // Mostrar todas as linhas
        document.querySelectorAll('table tbody tr').forEach(tr => {
          tr.style.display = '';
        });
      });

      // Filtros em tempo real (apenas filtro de texto)
      document.getElementById('filterAlunoSearch').addEventListener('input', function() {
        // Debounce para não executar a cada tecla
        clearTimeout(this.timeout);
        this.timeout = setTimeout(() => {
          // Aplicar apenas filtro de texto, ignorando dropdowns
          const searchValue = this.value.trim().toLowerCase();

          document.querySelectorAll('table tbody tr').forEach(tr => {
            const cols = tr.children;
            if (cols.length < 5) return;

            const nProcesso = (cols[0]?.textContent || '').toLowerCase();
            const nome = (cols[1]?.textContent || '').toLowerCase();

            let matches = true;

            // Filtro de pesquisa (nome ou nº processo)
            if (searchValue) {
              matches = matches && (nProcesso.includes(searchValue) || nome.includes(searchValue));
            }

            tr.style.display = matches ? '' : 'none';
          });
        }, 300);
      });
    });
  </script>

{% endblock %}