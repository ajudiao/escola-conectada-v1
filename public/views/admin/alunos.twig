{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left"><button class="mobile-toggle">☰</button>
          <h1 class="header-title">Alunos</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Alunos</h2>
            <p class="page-subtitle">Lista de alunos inscritos</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#alunoModal">Novo Aluno</button>
        </div>

        <!-- Filters -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-5">
                <label class="form-label">Pesquisar</label>
                <input id="filterAlunoSearch" type="text" class="form-control" placeholder="Nome ou nº processo">
              </div>
              <div class="col-md-3">
                <label class="form-label">Curso</label>
                <select id="filterAlunoCurso" class="form-control form-select">
                  <option value="">Todos</option>
                  <option>Informática</option>
                  <option>Física</option>
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label">Ano</label>
                <select id="filterAlunoAno" class="form-control form-select">
                  <option value="">Todos</option>
                  <option>10ª</option>
                  <option>11ª</option>
                </select>
              </div>
              <div class="col-md-2">
                <button id="btnFilterAluno" class="btn btn-outline-primary w-100">Filtrar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Nº Processo</th>
                    <th>Nome</th>
                    <th>Contacto</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>2026-001</td>
                    <td>Ana Pereira</td>
                    <td>+244 922 000 004</td>
                    <td>
                      <a href="/admin/aluno/show" class="btn btn-sm btn-outline-info me-1">Ver</a>
                      <button class="btn btn-sm btn-outline-secondary me-1 btn-edit" data-bs-toggle="modal"
                        data-bs-target="#alunoModal" data-nome="Ana Pereira" data-processo="2026-001"
                        data-nascimento="2010-05-12" data-sexo="Feminino"
                        data-email="ana.pereira@escola.med.ao" data-contato="+244 922 000 004"
                        data-turma="1" data-codigo-encarregado="ENC-001">Editar</button>
                      <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </td>
                  </tr>
                  
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Modal: Adicionar / Editar Aluno -->
        <div class="modal fade" id="alunoModal" tabindex="-1">
          <div class="modal-dialog modal-lg">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="alunoModalTitle">Novo Aluno</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <form id="formAluno" action="processar_aluno.php" method="post">
                        <div class="modal-body">
                  <input type="hidden" id="alunoId" name="alunoId" value="">

                  <div class="mb-4 p-3 border rounded bg-light">
                    <h6 class="mb-3">Dados Pessoais</h6>
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label class="form-label">Nome Completo</label>
                        <input id="alunoNome" name="alunoNome" class="form-control" required>
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Nº Processo</label>
                        <input id="alunoProcesso" name="alunoProcesso" class="form-control" required>
                      </div>
                      <div class="col-md-4">
                        <label class="form-label">Data de Nascimento</label>
                        <input id="alunoNascimento" name="alunoNascimento" class="form-control" type="date" required>
                      </div>
                      <div class="col-md-4">
                        <label class="form-label">Sexo</label>
                        <select id="alunoSexo" name="alunoSexo" class="form-select" required>
                          <option value="">Selecione...</option>
                          <option value="Masculino">Masculino</option>
                          <option value="Feminino">Feminino</option>
                          <option value="Outro">Outro</option>
                        </select>
                      </div>
                      <div class="col-md-4">
                        <label class="form-label">Nacionalidade</label>
                        <input id="alunoNacionalidade" name="alunoNacionalidade" class="form-control" type="text" placeholder="Ex: Angolana" required>
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input id="alunoEmail" name="alunoEmail" class="form-control" type="email">
                      </div>
                      <div class="col-md-6">
                        <label class="form-label">Telefone/Contacto</label>
                        <input id="alunoContacto" name="alunoContacto" class="form-control" type="tel" required>
                      </div>
                    </div>
                  </div>

                  <div class="mb-4 p-3 border rounded bg-light">
                    <h6 class="mb-3">Turma</h6>
                    <div class="row g-3">
                      <div class="col-md-12">
                        <label class="form-label">Selecione uma Turma</label>
                        <div class="border rounded p-3">
                          <div class="form-check">
                            <input class="form-check-input turma-radio" type="checkbox" id="turma_1" name="alunoTurma" value="1">
                            <label class="form-check-label" for="turma_1">
                              <strong>4A</strong> — Manhã — Sala 04
                            </label>
                          </div>
                          <div class="form-check">
                            <input class="form-check-input turma-radio" type="checkbox" id="turma_2" name="alunoTurma" value="2">
                            <label class="form-check-label" for="turma_2">
                              <strong>4B</strong> — Tarde — Sala 12
                            </label>
                          </div>
                          <div class="form-check">
                            <input class="form-check-input turma-radio" type="checkbox" id="turma_3" name="alunoTurma" value="3">
                             <label class="form-check-label" for="turma_3">
                              <strong>4C</strong> — Noite — Sala 15
                            </label>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="mb-4 p-3 border rounded bg-light">
                    <h6 class="mb-3">Responsável</h6>
                    <p class="text-muted small mb-3">⚠️ Certifique-se de que o encarregado já está adicionado no sistema. Utilize o código do encarregado para associá-lo a este aluno.</p>
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label class="form-label">Código do Responsável</label>
                        <input id="alunoCodigoEncarregado" name="alunoCodigoEncarregado" class="form-control" type="text" placeholder="Ex: ENC-001" required>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                  <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
      
      {% include 'components/footer.twig' %}
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-edit');
        if (!btn) return;
        const nome = btn.getAttribute('data-nome') || '';
        const processo = btn.getAttribute('data-processo') || '';
        const nascimento = btn.getAttribute('data-nascimento') || '';
        const sexo = btn.getAttribute('data-sexo') || '';
        const email = btn.getAttribute('data-email') || '';
        const contacto = btn.getAttribute('data-contacto') || '';
        const turma = btn.getAttribute('data-turma') || '';
        const codigoEncarregado = btn.getAttribute('data-codigo-encarregado') || '';

        document.getElementById('alunoModalTitle').textContent = 'Editar Aluno';
        document.getElementById('alunoNome').value = nome;
        document.getElementById('alunoProcesso').value = processo;
        document.getElementById('alunoNascimento').value = nascimento;
        document.getElementById('alunoSexo').value = sexo;
        document.getElementById('alunoEmail').value = email;
        document.getElementById('alunoContacto').value = contacto;
        
        // Marcar a turma correta
        document.querySelectorAll('.turma-radio').forEach(cb => cb.checked = false);
        if (turma) {
          const turmaCb = document.getElementById('turma_' + turma);
          if (turmaCb) {
            turmaCb.checked = true;
            document.getElementById('turmaCheckboxes').style.display = 'flex';
          }
        }
        
        document.getElementById('alunoCodigoEncarregado').value = codigoEncarregado;
      });

      const alunoModalEl = document.getElementById('alunoModal');
      alunoModalEl.addEventListener('hidden.bs.modal', function () {
        document.getElementById('alunoModalTitle').textContent = 'Novo Aluno';
        document.getElementById('formAluno').reset();
        document.querySelectorAll('.turma-radio').forEach(cb => cb.checked = false);
      });

      // Apenas uma turma pode ser marcada por vez
      document.querySelectorAll('.turma-radio').forEach(checkbox => {
        checkbox.addEventListener('change', function () {
          if (this.checked) {
            // Desmarcar todos os outros
            document.querySelectorAll('.turma-radio').forEach(cb => {
              if (cb !== this) cb.checked = false;
            });
          }
        });
      });

      // Submissão do formulário ficará a cargo do backend PHP puro.
      // O formulário usa action="processar_aluno.php" e method="post" para envio normal.
    });
  </script>

{% endblock %}