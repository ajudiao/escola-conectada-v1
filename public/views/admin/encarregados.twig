{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left"><button class="mobile-toggle">☰</button>
          <h1 class="header-title">Encarregados</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <!-- Flash Messages -->
        {% if flashMessages %}
          {% for message in flashMessages %}
            <div class="alert alert-{{ message.type == 'success' ? 'success' : (message.type == 'warning' ? 'warning' : 'danger') }} alert-dismissible fade show" role="alert">
              {{ message.message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endif %}

        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Encarregados</h2>
            <p class="page-subtitle">Adicionar e gerir encarregados e os seus educandos</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#encModal">Novo Encarregado</button>
        </div>

        <!-- Filters -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-5">
                <label class="form-label">Pesquisar</label>
                <input id="filterEncSearch" type="text" class="form-control" placeholder="Nome, contacto ou email">
              </div>
              <div class="col-md-7">
                <button id="btnFilterEnc" class="btn btn-outline-primary">Filtrar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Contacto</th>
                    <th>Email</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody id="listaEncarregados">
                  {% if encarregados %}
                    {% for encarregado in encarregados %}
                      <tr>
                        <td>{{ encarregado.nome_completo }}</td>
                        <td>{{ encarregado.telefone }}</td>
                        <td>{{ encarregado.email }}</td>
                        <td>
                          <button type="button" class="btn btn-sm btn-outline-info me-1" title="Ver Detalhes"
                            onclick="verEncarregado({{ encarregado.id }})">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                              <circle cx="12" cy="12" r="3"/>
                            </svg>
                          </button>
                          <button type="button" class="btn btn-sm btn-outline-secondary me-1 btn-edit-enc" title="Editar"
                            data-bs-toggle="modal" data-bs-target="#encModal"
                            data-id="{{ encarregado.id }}"
                            data-nome="{{ encarregado.nome_completo }}"
                            data-email="{{ encarregado.email }}"
                            data-telefone="{{ encarregado.telefone }}"
                            data-telefone-alternativo="{{ encarregado.telefone_alternativo }}"
                            data-endereco="{{ encarregado.endereco }}"
                            data-nascimento="{{ encarregado.data_nascimento }}"
                            data-identidade="{{ encarregado.n_identidade }}"
                            data-profissao="{{ encarregado.profissao }}"
                            data-relacao="{{ encarregado.relacao_educando }}">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                          </button>
                          <button type="button" class="btn btn-sm btn-outline-danger" title="Eliminar"
                            onclick="confirmarDelecao({{ encarregado.id }}, '{{ encarregado.nome_completo | escape('js') }}')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="3 6 5 6 21 6"/>
                              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                            </svg>
                          </button>
                        </td>
                      </tr>
                    {% endfor %}
                  {% else %}
                    <tr>
                      <td colspan="4" class="text-center py-5">
                        <div class="alert alert-info d-inline-block" role="alert">
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                            class="me-2" style="display: inline; vertical-align: text-bottom;">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                          </svg>
                          Nenhum encarregado registado ainda.
                        </div>
                      </td>
                    </tr>
                  {% endif %}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        {% include 'components/encarregado-modal.twig' %}
      </div>

      {% include 'components/footer.twig' %}
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Busca em tempo real
      document.getElementById('filterEncSearch').addEventListener('input', function() {
        // Debounce para não executar a cada tecla
        clearTimeout(this.timeout);
        this.timeout = setTimeout(() => {
          const searchValue = this.value.trim().toLowerCase();

          document.querySelectorAll('#listaEncarregados tr').forEach(tr => {
            const cols = tr.children;
            if (cols.length < 4) return;

            const nome = (cols[0]?.textContent || '').toLowerCase();
            const contacto = (cols[1]?.textContent || '').toLowerCase();
            const email = (cols[2]?.textContent || '').toLowerCase();

            let matches = true;

            // Filtro de pesquisa (nome, contacto, email)
            if (searchValue) {
              matches = matches && (
                nome.includes(searchValue) ||
                contacto.includes(searchValue) ||
                email.includes(searchValue)
              );
            }

            tr.style.display = matches ? '' : 'none';
          });
        }, 300);
      });

      // Botão de filtro (compatibilidade)
      document.getElementById('btnFilterEnc').addEventListener('click', function () {
        // A busca em tempo real já filtra automaticamente
      });
    });

    function verEncarregado(id) {
      window.location.href = '/admin/encarregados/' + id;
    }

    function confirmarDelecao(id, nome) {
      if (confirm('Tem certeza que deseja eliminar o encarregado "' + nome + '"?')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/encarregados/' + id + '/delete';

        const methodField = document.createElement('input');
        methodField.type = 'hidden';
        methodField.name = '_method';
        methodField.value = 'DELETE';
        form.appendChild(methodField);

        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>

{% endblock %}