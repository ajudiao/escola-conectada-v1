{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left"><button class="mobile-toggle">☰</button>
          <h1 class="header-title">Encarregados</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Encarregados</h2>
            <p class="page-subtitle">Adicionar e gerir encarregados e os seus educandos</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#encModal">Novo Encarregado</button>
        </div>

        <!-- Filters -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-5">
                <label class="form-label">Pesquisar</label>
                <input id="filterEncSearch" type="text" class="form-control" placeholder="Nome, contacto ou email">
              </div>
              <div class="col-md-7">
                <button id="btnFilterEnc" class="btn btn-outline-primary">Filtrar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Contacto</th>
                    <th>Email</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody id="listaEncarregados">
                  <tr>
                    <td>Maria José Santos</td>
                    <td>+244 912 345 678</td>
                    <td>maria.santos@email.ao</td>
                    <td>
                      <a href="/admin/encarregado/show" class="btn btn-sm btn-outline-info me-1">Ver</a>
                      <button class="btn btn-sm btn-outline-secondary me-1 btn-edit-enc" data-bs-toggle="modal"
                        data-bs-target="#encModal" data-id="1" data-nome="Maria José Santos" data-nascimento="1978-05-15"
                        data-identidade="00123456LA89" data-profissao="Professora" data-endereco="Rua da Paz, 45, Luanda"
                        data-contacto="+244 912 345 678" data-contacto-alt="+244 913 456 789"
                        data-email="maria.santos@email.ao" data-relacao="Mãe">Editar</button>
                      <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </td>
                  </tr>
                  <tr>
                    <td>António Silva</td>
                    <td>+244 923 111 222</td>
                    <td>antonio.silva@email.ao</td>
                    <td>
                      <a href="encarregado-detalhes.html" class="btn btn-sm btn-outline-info me-1">Ver</a>
                      <button class="btn btn-sm btn-outline-secondary me-1 btn-edit-enc" data-bs-toggle="modal"
                        data-bs-target="#encModal" data-id="2" data-nome="António Silva" data-nascimento="1975-08-22"
                        data-identidade="00234567LA90" data-profissao="Engenheiro" data-endereco="Avenida Angola, 123, Bengo"
                        data-contacto="+244 923 111 222" data-contacto-alt="+244 924 222 333"
                        data-email="antonio.silva@email.ao" data-relacao="Pai">Editar</button>
                      <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Modal: Adicionar / Editar Encarregado -->
        <div class="modal fade" id="encModal" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="encModalTitle">Novo Encarregado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <form id="formEncarregado" action="processar_encarregado.php" method="post">
                <div class="modal-body">
                  <input type="hidden" id="encId" name="encId" value="">
                  <div class="mb-3"><label class="form-label">Nome</label><input id="encNome" name="encNome" class="form-control">
                  </div>
                  <div class="row">
                    <div class="col-md-6 mb-3"><label class="form-label">Data de Nascimento</label><input id="encNascimento" name="encNascimento" type="date" class="form-control"></div>
                    <div class="col-md-6 mb-3"><label class="form-label">Número de Identidade</label><input id="encIdentidade" name="encIdentidade" class="form-control"></div>
                  </div>
                  <div class="mb-3"><label class="form-label">Profissão</label><input id="encProfissao" name="encProfissao" class="form-control">
                  </div>
                  <div class="mb-3"><label class="form-label">Endereço</label><input id="encEndereco" name="encEndereco" class="form-control">
                  </div>
                  <div class="row">
                    <div class="col-md-6 mb-3"><label class="form-label">Contacto</label><input id="encContacto" name="encContacto" class="form-control"></div>
                    <div class="col-md-6 mb-3"><label class="form-label">Número Alternativo</label><input id="encContactoAlt" name="encContactoAlt" class="form-control"></div>
                  </div>
                  <div class="mb-3"><label class="form-label">Email</label><input id="encEmail" name="encEmail" class="form-control">
                  </div>
                  <div class="mb-3"><label class="form-label">Relação com Educandos</label><input id="encRelacao" name="encRelacao" class="form-control" placeholder="Ex: Mãe, Pai, Avó, Tutor">
                  </div>
                  <div class="mb-3"><label class="form-label">Senha Inicial</label><input id="encSenha" name="encSenha" type="password" class="form-control" placeholder="Senha para login inicial"></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-outline-secondary"
                    data-bs-dismiss="modal">Cancelar</button><button type="submit"
                    class="btn btn-primary">Guardar</button></div>
              </form>
            </div>
          </div>
        </div>
      </div>

      {% include 'components/footer.twig' %}
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Edit button population
      document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-edit-enc');
        if (!btn) return;
        const id = btn.getAttribute('data-id') || '';
        const nome = btn.getAttribute('data-nome') || '';
        const contacto = btn.getAttribute('data-contacto') || '';
        const email = btn.getAttribute('data-email') || '';
        const nascimento = btn.getAttribute('data-nascimento') || '';
        const identidade = btn.getAttribute('data-identidade') || '';
        const profissao = btn.getAttribute('data-profissao') || '';
        const endereco = btn.getAttribute('data-endereco') || '';
        const contactoAlt = btn.getAttribute('data-contacto-alt') || '';
        const relacao = btn.getAttribute('data-relacao') || '';

        document.getElementById('encModalTitle').textContent = 'Editar Encarregado';
        document.getElementById('encId').value = id;
        document.getElementById('encNome').value = nome;
        document.getElementById('encNascimento').value = nascimento;
        document.getElementById('encIdentidade').value = identidade;
        document.getElementById('encProfissao').value = profissao;
        document.getElementById('encEndereco').value = endereco;
        document.getElementById('encContacto').value = contacto;
        document.getElementById('encContactoAlt').value = contactoAlt;
        document.getElementById('encEmail').value = email;
        document.getElementById('encRelacao').value = relacao;
        document.getElementById('encSenha').value = '';
      });

      const encModalEl = document.getElementById('encModal');
      encModalEl.addEventListener('hidden.bs.modal', function () {
        document.getElementById('encModalTitle').textContent = 'Novo Encarregado';
        document.getElementById('formEncarregado').reset();
        document.getElementById('encSenha').type = 'password';
      });

      // Form submit will be handled by PHP
      // Modal will close after PHP redirect/response

      // Simple filter implementation (client-side)
      document.getElementById('btnFilterEnc').addEventListener('click', function () {
        const q = document.getElementById('filterEncSearch').value.toLowerCase().trim();
        const rows = Array.from(document.querySelectorAll('#listaEncarregados tr'));
        rows.forEach(r => {
          const nome = r.children[0].textContent.toLowerCase();
          const contacto = r.children[1].textContent.toLowerCase();
          const email = r.children[2].textContent.toLowerCase();
          let visible = true;
          if (q && !(nome.includes(q) || contacto.includes(q) || email.includes(q))) visible = false;
          r.style.display = visible ? '' : 'none';
        });
      });
    });
  </script>

{% endblock %}