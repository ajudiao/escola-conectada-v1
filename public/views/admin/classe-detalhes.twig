{% extends "layouts/admin.twig" %}
{% block content %}

        <main class="main-content">
            <header class="main-header">
                <div class="header-left"><button class="mobile-toggle">☰</button>
                    <h1 class="header-title">Detalhes da Classe</h1>
                </div>
                <div class="header-right">
                    <div class="header-user">
                        <div class="header-user-avatar">AD</div>
                        <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                                class="header-user-role">Administração</span></div>
                    </div>
                </div>
            </header>

            <div class="page-content">
                <a href="classes.html" class="btn-back btn btn-outline-secondary mb-3">← Voltar</a>

                <div class="detail-header">
                    <h1 class="detail-title">4ª Classe</h1>
                    <p class="detail-subtitle">Classe: 4ª • Turmas: 4A • Alunos: 20</p>
                </div>

                <h2 class="section-header">Informações da Classe</h2>
                <div class="info-grid">
                    <div class="info-item"><span class="info-label">Classe</span>
                        <div class="info-value">4ª Classe</div>
                    </div>
                    <div class="info-item"><span class="info-label">Nível Educativo</span>
                        <div class="info-value">Ensino Básico</div>
                    </div>
                    <div class="info-item"><span class="info-label">Total de Turmas</span>
                        <div class="info-value">4</div>
                    </div>
                    <div class="info-item"><span class="info-label">Total de Alunos</span>
                        <div class="info-value">120</div>
                    </div>
                    <div class="info-item"><span class="info-label">Ano Letivo</span>
                        <div class="info-value">2025/2026</div>
                    </div>
                </div>

                <h2 class="section-header">Descrição</h2>
                <div class="info-item mb-3">
                    <div class="info-value">A 4ª Classe é a série intermediária do Ensino Básico, consolidando conhecimentos em 
                        língua portuguesa, matemática, ciências, história, geografia e educação física. Apresenta importante transição 
                        na complexidade de conteúdos e capacidades de raciocínio.
                    </div>
                </div>

                <h2 class="section-header">Disciplinas da Classe</h2>
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Disciplina</th>
                                <th>Horas/Semana</th>
                                <th>Professores Responsáveis</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Português</td>
                                <td>5</td>
                                <td>Cecília Matos, João Silva</td>
                            </tr>
                            <tr>
                                <td>Matemática</td>
                                <td>5</td>
                                <td>Manuel Sousa, Joana Costa</td>
                            </tr>
                            <tr>
                                <td>Ciências</td>
                                <td>3</td>
                                <td>Bruno Ferreira</td>
                            </tr>
                            <tr>
                                <td>História</td>
                                <td>2</td>
                                <td>Daniela Oliveira</td>
                            </tr>
                            <tr>
                                <td>Geografia</td>
                                <td>2</td>
                                <td>Paulo Rodrigues</td>
                            </tr>
                            <tr>
                                <td>Educação Física</td>
                                <td>2</td>
                                <td>André Mendes</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h2 class="section-header">Turmas Associadas</h2>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Identificação</th>
                                <th>Turno</th>
                                <th>Sala</th>
                                <th>Alunos</th>
                                <th>Prof. Titular</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>4A</td>
                                <td>Manhã</td>
                                <td>B201</td>
                                <td>30</td>
                                <td>Cecília Matos</td>
                                <td><a href="turma-detalhes.html" class="btn btn-sm btn-outline-info">Ver</a></td>
                            </tr>
                            <tr>
                                <td>4B</td>
                                <td>Manhã</td>
                                <td>B202</td>
                                <td>32</td>
                                <td>João Silva</td>
                                <td><a href="turma-detalhes.html" class="btn btn-sm btn-outline-info">Ver</a></td>
                            </tr>
                            <tr>
                                <td>4C</td>
                                <td>Afternoon</td>
                                <td>C301</td>
                                <td>29</td>
                                <td>Manuel Sousa</td>
                                <td><a href="turma-detalhes.html" class="btn btn-sm btn-outline-info">Ver</a></td>
                            </tr>
                         
                        </tbody>
                    </table>
                </div>

                                <div class="action-buttons">
                                        <button id="btnEditClass" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#classModal">Editar Classe</button>
                                        <button class="btn btn-outline-danger">Eliminar Classe</button>
                                </div>

                                <!-- Modal: Editar Classe (reutiliza estrutura) -->
                                <div class="modal fade" id="classModal" tabindex="-1">
                                    <div class="modal-dialog modal-lg">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title" id="classModalTitle">Editar Classe</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form id="formClass">
                                                <div class="modal-body">
                                                    <input type="hidden" id="classId" value="">
                                                    <div class="mb-3">
                                                        <label class="form-label">Série da Classe</label>
                                                        <select id="classNumero" class="form-select form-control">
                                                            <option value="">Selecione a série</option>
                                                            <option value="1">1ª Classe</option>
                                                            <option value="2">2ª Classe</option>
                                                            <option value="3">3ª Classe</option>
                                                            <option value="4" selected>4ª Classe</option>
                                                            <option value="5">5ª Classe</option>
                                                            <option value="6">6ª Classe</option>
                                                            <option value="7">7ª Classe</option>
                                                            <option value="8">8ª Classe</option>
                                                            <option value="9">9ª Classe</option>
                                                        </select>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Nome da Classe</label>
                                                        <input id="classNome" class="form-control" value="4ª Classe">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Descrição</label>
                                                        <textarea id="classDesc" class="form-control" rows="3" placeholder="Descrição da classe..."></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                    <button type="submit" class="btn btn-primary">Guardar</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

            </div>

            <footer class="main-footer">
                <p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p>
            </footer>
        </main>
    </div>

    
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const classModalEl = document.getElementById('classModal');

                document.getElementById('formClass').addEventListener('submit', function (e) {
                    e.preventDefault();
                    const data = {
                        numero: document.getElementById('classNumero').value,
                        nome: document.getElementById('classNome').value,
                        descricao: document.getElementById('classDesc').value
                    };
                    console.log('Salvar classe (stub):', data);
                    bootstrap.Modal.getInstance(classModalEl).hide();
                });
            });
        </script>

{% endblock %}