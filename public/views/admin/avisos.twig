{% extends "layouts/admin.twig" %}
{% block content %}
    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      {% include 'components/header.twig' %}

      <!-- Page Content -->
      <div class="page-content">
        <!-- Flash Messages -->
        {% if flashMessages %}
          {% for message in flashMessages %}
            <div class="alert alert-{{ message.type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
              {{ message.message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endif %}

        <!-- Page Header -->
        <div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
          <div>
            <h2 class="page-title">Gestão de Avisos</h2>
            <p class="page-subtitle mb-0">Publique avisos para toda a comunidade escolar</p>
          </div>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#novoAvisoModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Novo Aviso
          </button>
        </div>

        <!-- Filters -->
        <div class="card mb-4">
          <div class="card-body">
            <form method="GET" action="/admin/avisos" class="row g-3 align-items-end mb-4">
              <div class="col-md-4">
                <label class="form-label">Pesquisar</label>
                <input type="text" class="form-control" name="search" placeholder="Título ou conteúdo..." value="{{ search is not null ? search : '' }}">
              </div>
              <div class="col-md-3">
                <label class="form-label">Destinatário</label>
                <select class="form-control form-select" name="destinatario">
                  <option value="">Todos</option>
                  <option value="geral" {% if destinatario == 'geral' %}selected{% endif %}>Geral</option>
                  <option value="professores" {% if destinatario == 'professores' %}selected{% endif %}>Professores</option>
                  <option value="encarregados" {% if destinatario == 'encarregados' %}selected{% endif %}>Encarregados</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">Prioridade</label>
                <select class="form-control form-select" name="prioridade">
                  <option value="">Todas</option>
                  <option value="normal" {% if prioridade == 'normal' %}selected{% endif %}>Normal</option>
                  <option value="alta" {% if prioridade == 'alta' %}selected{% endif %}>Alta</option>
                  <option value="urgente" {% if prioridade == 'urgente' %}selected{% endif %}>Urgente</option>
                </select>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">Filtrar</button>
              </div>
              {% if search or destinatario or prioridade %}
                <div class="col-md-12">
                  <a href="/admin/avisos" class="btn btn-sm btn-outline-secondary">Limpar Filtros</a>
                </div>
              {% endif %}
            </form>

        <!-- Avisos List -->
        <div class="avisos-list">
          {% if avisos %}
            {% for aviso in avisos %}
              <div class="aviso-item">
                <div class="aviso-header">
                  <div>
                    <h5 class="aviso-title">{{ aviso.titulo }}</h5>
                    <span class="badge badge-{{ aviso.destinatario == 'geral' ? 'info' : (aviso.destinatario == 'professores' ? 'warning' : 'primary') }}">
                      {{ aviso.destinatario | capitalize }}
                    </span>
                    {% if aviso.prioridade == 'urgente' %}
                      <span class="badge badge-danger ms-1">Urgente</span>
                    {% elseif aviso.prioridade == 'alta' %}
                      <span class="badge badge-warning ms-1">Alta Prioridade</span>
                    {% endif %}
                  </div>
                  <span class="aviso-date">{{ aviso.created_at | date('d \\d\\e F \\d\\e Y') }}</span>
                </div>
                <p class="aviso-content">
                  {{ aviso.conteudo }}
                </p>
                <div class="aviso-footer">
                  <span>Publicado por: Admin</span>
                  <span class="ms-auto">
                    <button type="button" class="btn btn-sm btn-outline-secondary me-1" title="Editar" 
                      onclick="editarAviso({{ aviso.id }}, '{{ aviso.titulo | escape('js') }}', '{{ aviso.conteudo | escape('js') }}', '{{ aviso.destinatario }}', '{{ aviso.prioridade }}')">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                      </svg>
                    </button>
                    <form method="POST" action="/admin/avisos/{{ aviso.id }}/delete" style="display: inline;" onsubmit="return confirmarDelecao('{{ aviso.titulo | escape('js') }}')">
                      <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="3 6 5 6 21 6" />
                          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                        </svg>
                      </button>
                    </form>
                  </span>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="alert alert-info mt-4" role="alert">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2" style="display: inline; vertical-align: text-bottom;">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
              </svg>
              Nenhum aviso publicado ainda. Clique em "Novo Aviso" para criar um.
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Footer -->
      <footer class="main-footer">
        <p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p>
      </footer>
    </main>
  </div>

  {% include 'components/aviso-modal.twig' %}

{% endblock %}