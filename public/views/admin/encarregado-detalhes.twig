{% extends "layouts/admin.twig" %}
{% block content %}

    <main class="main-content">
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">☰</button>
          <h1 class="header-title">Detalhes do Encarregado</h1>
        </div>
        <div class="header-right">
          <div class="header-user"><div class="header-user-avatar">AD</div><div class="header-user-info"><span class="header-user-name">Administrador</span><span class="header-user-role">Administração</span></div></div>
        </div>
      </header>

      <div class="page-content">
        <a href="encarregados.html" class="btn-back btn btn-outline-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Voltar
        </a>

        <!-- Header Section -->
        <div class="detail-header">
          <h1 class="detail-title">Maria José Santos</h1>
          <p class="detail-subtitle">Encarregada de Educação (Ativo)</p>
        </div>

        <!-- Informações Pessoais -->
        <h2 class="section-header">Informações Pessoais</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Telefone</span>
            <div class="info-value">+244 912 345 678</div>
          </div>
          <div class="info-item">
            <span class="info-label">Email</span>
            <div class="info-value">maria.santos@email.ao</div>
          </div>
          <div class="info-item">
            <span class="info-label">Data de Nascimento</span>
            <div class="info-value">22 de Julho de 1980</div>
          </div>
          <div class="info-item">
            <span class="info-label">Número de ID</span>
            <div class="info-value">000321654987</div>
          </div>
          <div class="info-item">
            <span class="info-label">Profissão</span>
            <div class="info-value">Professora Reformada</div>
          </div>
          <div class="info-item">
            <span class="info-label">Endereço</span>
            <div class="info-value">Rua do Comerciante, nº 87, Luanda</div>
          </div>
        </div>

        <!-- Educandos -->
        <h2 class="section-header">Educandos Inscritos</h2>
        <div class="table-responsive-custom">
          <table class="table table-custom align-middle">
            <thead>
              <tr>
                <th>Nome do Aluno</th>
                <th>Nº Processo</th>
                <th>Curso</th>
                <th>Turma</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Ana Maria Santos</strong></td>
                <td>2026-001</td>
                <td>Informática</td>
                <td>EIA-10AD</td>
                <td><span class="badge bg-success">Ativo</span></td>
              </tr>
              <tr>
                <td><strong>Pedro João Santos</strong></td>
                <td>2026-025</td>
                <td>Administração</td>
                <td>INFGEST-11AD</td>
                <td><span class="badge bg-success">Ativo</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Informações de Contacto Adicional -->
        <h2 class="section-header">Contacto Alternativo</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Telemóvel Alternativo</span>
            <div class="info-value">+244 912 345 679</div>
          </div>
          <div class="info-item">
            <span class="info-label">Relação com Educandos</span>
            <div class="info-value">Mãe</div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
          <button class="btn btn-primary">Editar Encarregado</button>
          <button class="btn btn-outline-secondary">Enviar Mensagem</button>
          <button class="btn btn-outline-danger">Eliminar Encarregado</button>
        </div>
      </div>

      <footer class="main-footer"><p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p></footer>
    </main>

{% endblock %}