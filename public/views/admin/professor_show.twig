{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">☰</button>
          <h1 class="header-title">Detalhes do Professor</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <!-- Flash Messages -->
        {% if flashMessages %}
          {% for message in flashMessages %}
            <div class="alert alert-{{ message.type == 'success' ? 'success' : (message.type == 'warning' ? 'warning' : 'danger') }} alert-dismissible fade show" role="alert">
              {{ message.message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endif %}

        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Professor: {{ professor.nome_completo }}</h2>
            <p class="page-subtitle">Informações detalhadas e atribuições</p>
          </div>
          <div>
            <a href="/admin/professores" class="btn btn-outline-secondary me-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
              </svg>
              Voltar
            </a>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#profModal">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
              Editar Professor
            </button>
          </div>
        </div>

        <div class="row">
          <!-- Informações Pessoais -->
          <div class="col-lg-8">
            <div class="card mb-4">
              <div class="card-header">
                <h5 class="card-title mb-0">Informações Pessoais</h5>
              </div>
              <div class="card-body">
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Nome Completo</label>
                      <p class="mb-0">{{ professor.nome_completo }}</p>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Email</label>
                      <p class="mb-0">{{ professor.email }}</p>
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Telefone</label>
                      <p class="mb-0">{{ professor.telefone }}</p>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Telefone Alternativo</label>
                      <p class="mb-0">{{ professor.telefone_alternativo ?: 'Não informado' }}</p>
                    </div>
                  </div>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Endereço</label>
                  <p class="mb-0">{{ professor.endereco ?: 'Não informado' }}</p>
                </div>
              </div>
            </div>

            <!-- Informações Acadêmicas -->
            <div class="card mb-4">
              <div class="card-header">
                <h5 class="card-title mb-0">Informações Acadêmicas</h5>
              </div>
              <div class="card-body">
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Grau Acadêmico</label>
                      <p class="mb-0">{{ professor.grau_academico }}</p>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Área de Formação</label>
                      <p class="mb-0">{{ professor.area_formacao }}</p>
                    </div>
                  </div>
                </div>
                <div class="row">
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Instituição de Formação</label>
                      <p class="mb-0">{{ professor.instituicao_formacao }}</p>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      <label class="form-label fw-bold">Ano de Conclusão</label>
                      <p class="mb-0">{{ professor.ano_conclusao }}</p>
                    </div>
                  </div>
                </div>
                {% if professor.numero_certificado %}
                <div class="mb-3">
                  <label class="form-label fw-bold">Número do Certificado</label>
                  <p class="mb-0">{{ professor.numero_certificado }}</p>
                </div>
                {% endif %}
                {% if professor.certificado_pdf %}
                <div class="mb-3">
                  <label class="form-label fw-bold">Certificado</label>
                  <p class="mb-0">
                    <a href="/uploads/certificados/{{ professor.certificado_pdf }}" target="_blank" class="btn btn-sm btn-outline-primary">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14,2 14,8 20,8"/>
                      </svg>
                      Ver Certificado
                    </a>
                  </p>
                </div>
                {% endif %}
              </div>
            </div>

            <!-- Atribuições -->
            <div class="card">
              <div class="card-header">
                <h5 class="card-title mb-0">Atribuições</h5>
              </div>
              <div class="card-body">
                {% if turmasAgrupadas %}
                  <div class="table-responsive">
                    <table class="table table-sm">
                      <thead>
                        <tr>
                          <th>Turma</th>
                          <th>Classe</th>
                          <th>Turno</th>
                          <th>Sala</th>
                          <th>Disciplinas Lecionadas</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for turmaId, turma in turmasAgrupadas %}
                          <tr>
                            <td><strong>{{ turma.codigo }}</strong></td>
                            <td>{{ turma.classe }}</td>
                            <td>{{ turma.turno }}</td>
                            <td>{{ turma.sala }}</td>
                            <td>
                              {% for disciplina in turma.disciplinas %}
                                <span class="badge bg-primary me-1 mb-1">{{ disciplina }}</span>
                              {% endfor %}
                            </td>
                          </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="text-center py-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"
                      class="text-muted mb-3">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                      <polyline points="14,2 14,8 20,8"/>
                      <line x1="16" y1="13" x2="8" y2="13"/>
                      <line x1="16" y1="17" x2="8" y2="17"/>
                      <polyline points="10,9 9,9 8,9"/>
                    </svg>
                    <p class="text-muted mb-0">Este professor ainda não foi atribuído a nenhuma turma.</p>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>

          <!-- Sidebar com Estatísticas -->
          <div class="col-lg-4">
            <div class="card mb-4">
              <div class="card-header">
                <h5 class="card-title mb-0">Estatísticas</h5>
              </div>
              <div class="card-body">
                {% if turmasAgrupadas %}
                  <div class="row text-center">
                    <div class="col-6">
                      <div class="stat-card">
                        <div class="stat-number">{{ turmasAgrupadas|length }}</div>
                        <div class="stat-label">Turmas</div>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="stat-card">
                        <div class="stat-number">
                          {% set totalDisciplinas = 0 %}
                          {% for turmaId, turma in turmasAgrupadas %}
                            {% set totalDisciplinas = totalDisciplinas + turma.disciplinas|length %}
                          {% endfor %}
                          {{ totalDisciplinas }}
                        </div>
                        <div class="stat-label">Disciplinas</div>
                      </div>
                    </div>
                  </div>
                {% else %}
                  <div class="row text-center">
                    <div class="col-6">
                      <div class="stat-card">
                        <div class="stat-number">0</div>
                        <div class="stat-label">Turmas</div>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="stat-card">
                        <div class="stat-number">0</div>
                        <div class="stat-label">Disciplinas</div>
                      </div>
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>

            <div class="card">
              <div class="card-header">
                <h5 class="card-title mb-0">Ações Rápidas</h5>
              </div>
              <div class="card-body">
                <div class="d-grid gap-2">
                  <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#profModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    Editar Professor
                  </button>
                  <button type="button" class="btn btn-outline-danger" onclick="confirmarDelecao({{ professor.id }}, '{{ professor.nome_completo | escape('js') }}')">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="3 6 5 6 21 6"/>
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    </svg>
                    Eliminar Professor
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        {% include 'components/professor-modal.twig' with {'turmas': turmas, 'disciplinas': disciplinas, 'professor': professor} %}
      </div>

      {% include 'components/footer.twig' %}
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Preencher modal de edição com dados do professor
      const editBtn = document.querySelector('[data-bs-target="#profModal"]');
      if (editBtn) {
        editBtn.addEventListener('click', function() {
          // Dados do professor
          document.getElementById('profId').value = '{{ professor.id }}';
          document.getElementById('profNome').value = '{{ professor.nome_completo | escape('js') }}';
          document.getElementById('profEmail').value = '{{ professor.email | escape('js') }}';
          document.getElementById('profTelefone').value = '{{ professor.telefone | escape('js') }}';
          document.getElementById('profTelefoneAlternativo').value = '{{ professor.telefone_alternativo | escape('js') }}';
          document.getElementById('profEndereco').value = '{{ professor.endereco | escape('js') }}';
          document.getElementById('profGrau').value = '{{ professor.grau_academico | escape('js') }}';
          document.getElementById('profArea').value = '{{ professor.area_formacao | escape('js') }}';
          document.getElementById('profInstituicao').value = '{{ professor.instituicao_formacao | escape('js') }}';
          document.getElementById('profAno').value = '{{ professor.ano_conclusao }}';
          document.getElementById('profNumeroCertificado').value = '{{ professor.numero_certificado | escape('js') }}';

          // Turmas e disciplinas
          {% if turmasDisciplinas %}
            {% for atribuicao in turmasDisciplinas %}
              // Marcar checkbox da turma
              const turmaCb = document.querySelector(`input[name="turmas[]"][value="{{ atribuicao.turma_id }}"]`);
              if (turmaCb) {
                turmaCb.checked = true;
                const select = document.querySelector(`select[data-turma-id="{{ atribuicao.turma_id }}"]`);
                if (select) {
                  select.disabled = false;
                  const option = select.querySelector(`option[value="{{ atribuicao.disciplina_id }}"]`);
                  if (option) option.selected = true;
                }
              }
            {% endfor %}
          {% endif %}

          document.getElementById('profModalTitle').textContent = 'Editar Professor';
        });
      }

      // Reset modal quando fechar
      const profModalEl = document.getElementById('profModal');
      profModalEl.addEventListener('hidden.bs.modal', function () {
        document.getElementById('profModalTitle').textContent = 'Novo Professor';
        document.getElementById('formProfessor').reset();
        document.querySelectorAll('.turma-disciplina-select').forEach(select => {
          select.disabled = true;
        });
      });
    });

    function confirmarDelecao(professorId, nomeProfessor) {
      if (confirm(`Tem certeza que deseja eliminar o professor "${nomeProfessor}"? Esta ação não pode ser desfeita.`)) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/professores/${professorId}/delete`;
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = '_method';
        input.value = 'DELETE';
        form.appendChild(input);
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
{% endblock %}
