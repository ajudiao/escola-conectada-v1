{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">☰</button>
          <h1 class="header-title">Detalhes do Professor</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info"><span class="header-user-name">Administrador</span><span
                class="header-user-role">Administração</span></div>
          </div>
        </div>
      </header>

      <div class="page-content">
        <a href="professores.html" class="btn-back btn btn-outline-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6" />
          </svg>
          Voltar
        </a>

        <!-- Header Section -->
        <div class="detail-header">
          <h1 class="detail-title">Maria João dos Santos</h1>
          <p class="detail-subtitle">Docente de Matemática (Ativo)</p>
        </div>

        <!-- Informações Pessoais -->
        <h2 class="section-header">Informações Pessoais</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Email</span>
            <div class="info-value">maria.joao@escola.med.ao</div>
          </div>
          <div class="info-item">
            <span class="info-label">Telefone</span>
            <div class="info-value">+244 923 000 002</div>
          </div>
          <div class="info-item">
            <span class="info-label">Data de Nascimento</span>
            <div class="info-value">15 de Junho de 1985</div>
          </div>
          <div class="info-item">
            <span class="info-label">Número de ID</span>
            <div class="info-value">000123456789</div>
          </div>
          <div class="info-item">
            <span class="info-label">Estado Civil</span>
            <div class="info-value">Casada</div>
          </div>
          <div class="info-item">
            <span class="info-label">Endereço</span>
            <div class="info-value">Rua da Educação, nº 45, Luanda</div>
          </div>
        </div>

        <!-- Informações Académicas -->
        <h2 class="section-header">Informações Académicas</h2>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Habilitações</span>
            <div class="info-value">Licenciatura em Matemática</div>
          </div>
          <div class="info-item">
            <span class="info-label">Instituição</span>
            <div class="info-value">Universidade de Luanda</div>
          </div>
          <div class="info-item">
            <span class="info-label">Data de Admissão</span>
            <div class="info-value">10 de Janeiro de 2013</div>
          </div>
        </div>

        <!-- Disciplinas Lecionadas -->
        <h2 class="section-header">Disciplinas Lecionadas</h2>
        <div class="table-responsive-custom">
          <table class="table table-custom align-middle">
            <thead>
              <tr>
                <th>Disciplina</th>
                <th>Turma</th>
                <th>Turno</th>
                <th>Horas/Semana</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Matemática</strong></td>
                <td>1A</td>
                <td>Matutino</td>
                <td>4</td>
              </tr>
              <tr>
                <td><strong>Matemática</strong></td>
                <td>8B</td>
                <td>Vespertino</td>
                <td>4</td>
              </tr>
             
            </tbody>
          </table>
        </div>

        <!-- Action Buttons -->
        <div class="action-buttons">
          <button id="btnEditProfessor" class="btn btn-primary" data-bs-toggle="modal"
            data-bs-target="#profModal">Editar Professor</button>
          <button class="btn btn-outline-danger">Eliminar Professor</button>
        </div>

        <!-- Modal: Adicionar / Editar Professor (reutilizado) -->
        <div class="modal fade" id="profModal" tabindex="-1">
          <div class="modal-dialog modal-lg">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="profModalTitle">Editar Professor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <form id="formProfessor">
                <div class="modal-body">
                  <input type="hidden" id="profId" value="">
                  <div class="mb-3">
                    <label class="form-label">Nome Completo</label>
                    <input type="text" id="profNome" class="form-control" required>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" id="profEmail" class="form-control" required>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Telefone</label>
                    <input type="tel" id="profTelefone" class="form-control">
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Disciplinas que Leciona</label>
                    <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_mat" value="Matemática"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_mat">Matemática</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_port" value="Português"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_port">Português</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_ing" value="Inglês" name="disciplinas">
                        <label class="form-check-label" for="disc_ing">Inglês</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_fis" value="Física" name="disciplinas">
                        <label class="form-check-label" for="disc_fis">Física</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_qui" value="Química"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_qui">Química</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_bio" value="Biologia"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_bio">Biologia</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_hist" value="História"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_hist">História</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_geo" value="Geografia"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_geo">Geografia</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_info" value="Informática"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_info">Informática</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="disc_ed" value="Educação Física"
                          name="disciplinas">
                        <label class="form-check-label" for="disc_ed">Educação Física</label>
                      </div>
                    </div>
                    <div class="mb-3">
                      <label class="form-label">Turmas</label>
                      <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                        <!-- Exemplos estáticos; idealmente carregar via API -->
                        <div class="form-check">
                          <input class="form-check-input turma-checkbox" type="checkbox" id="turma_1" value="1"
                            name="turmas">
                          <label class="form-check-label" for="turma_1">INFGEST-10AD1 <small class="text-muted">• Turno:
                              Manhã — Sala: A101</small></label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input turma-checkbox" type="checkbox" id="turma_2" value="2"
                            name="turmas">
                          <label class="form-check-label" for="turma_2">Turma B1 <small class="text-muted">• Turno:
                              Tarde — Sala: B202</small></label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input turma-checkbox" type="checkbox" id="turma_3" value="3"
                            name="turmas">
                          <label class="form-check-label" for="turma_3">Turma C1 <small class="text-muted">• Turno:
                              Noite — Sala: C303</small></label>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                  <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>

      <footer class="main-footer">
        <p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p>
      </footer>
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const profModalEl = document.getElementById('profModal');

      // When modal shown, populate fields from the details page
      profModalEl.addEventListener('show.bs.modal', function () {
        const nome = document.querySelector('.detail-title')?.textContent.trim() || '';
        const email = Array.from(document.querySelectorAll('.info-item')).find(i => i.querySelector('.info-label')?.textContent.trim() === 'Email')?.querySelector('.info-value')?.textContent.trim() || '';
        const telefone = Array.from(document.querySelectorAll('.info-item')).find(i => i.querySelector('.info-label')?.textContent.trim() === 'Telefone')?.querySelector('.info-value')?.textContent.trim() || '';

        document.getElementById('profModalTitle').textContent = 'Editar Professor';
        document.getElementById('profNome').value = nome;
        document.getElementById('profEmail').value = email;
        document.getElementById('profTelefone').value = telefone;

        // mark disciplines based on the Disciplinas Lecionadas table
        const disciplinas = Array.from(document.querySelectorAll('.table-custom tbody tr')).map(r => r.children[0]?.textContent.trim()).filter(Boolean).map(s => s.replace(/\n/g, '').trim());
        document.querySelectorAll('input[name="disciplinas"]').forEach(cb => {
          cb.checked = disciplinas.some(d => d.toLowerCase().includes(cb.value.toLowerCase()));
        });
      });

      // Simple submit stub
      document.getElementById('formProfessor').addEventListener('submit', function (e) {
        e.preventDefault();
        const disciplinas = Array.from(document.querySelectorAll('input[name="disciplinas"]:checked')).map(i => i.value);
        const data = {
          nome: document.getElementById('profNome').value,
          email: document.getElementById('profEmail').value,
          telefone: document.getElementById('profTelefone').value,
          disciplinas: disciplinas
        };
        console.log('Salvar professor (stub):', data);
        bootstrap.Modal.getInstance(profModalEl).hide();
      });
    });
  </script>
{% endblock %}
