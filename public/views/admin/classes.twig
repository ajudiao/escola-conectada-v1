{% extends "layouts/admin.twig" %}
{% block content %}
    <main class="main-content">
      
      {% include 'components/header.twig' %}

      <div class="page-content">
          {% if flashMessages %}
          {% for message in flashMessages %}
            <div class="alert alert-{{ message.type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
              {{ message.message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endif %}
        <div class="page-header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="page-title">Gestão de Classes</h2>
            <p class="page-subtitle">Classes do Ensino Básico (1ª até 9ª)</p>
          </div>
          <button id="btnNewClass" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#classModal">Nova Classe</button>
        </div>

        <!-- Filters -->
        <div class="card mb-3">
          <div class="card-body">
            <div class="row g-3 align-items-end">
              <div class="col-md-6">
                <label class="form-label">Pesquisar</label>
                <input id="filterClassSearch" type="text" class="form-control" placeholder="Número ou nome da classe">
              </div>
              <div class="col-md-4">
                <label class="form-label">Classe</label>
                <select id="filterClassSerie" class="form-control form-select">
                  <option value="">Todas</option>
                  <option>1ª</option>
                  <option>2ª</option>
                  <option>3ª</option>
                  <option>4ª</option>
                  <option>5ª</option>
                  <option>6ª</option>
                  <option>7ª</option>
                  <option>8ª</option>
                  <option>9ª</option>
                </select>
              </div>
              <div class="col-md-2">
                <button id="btnFilterClass" class="btn btn-outline-primary w-100">Filtrar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Classe</th>
                    <th>Disciplinas</th>
                    <th>Turmas</th>
                    <th>Descrição</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  {% for classe in classes %}
                  <tr>
                    <td><span class="badge bg-info">{{ classe.nome }}</span></td>
                    <td>{{ classe.num_disciplinas }} disciplinas</td>
                    <td>{{ classe.num_turmas }} turmas</td> <!-- Placeholder, ajustar depois -->
                    <td>{{ classe.descricao }}</td>
                    <td>
                      <a href="/admin/classe/show/{{ classe.id }}" class="btn btn-sm btn-outline-info me-1">Ver</a>
                      <button class="btn btn-sm btn-outline-secondary me-1 btn-edit" data-bs-toggle="modal"
                        data-bs-target="#classModal" data-id="{{ classe.id }}" data-nome="{{ classe.nome }}">Editar</button>
                      <form method="POST" action="/admin/classes/{{ classe.id }}/delete" style="display: inline;" onsubmit="return confirm('Tem certeza que deseja eliminar esta classe?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                      </form>
                    </td>
                  </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        {% include 'components/class-modal.twig' %}
      </div>
      <footer class="main-footer">
        <p class="mb-0">Escola Conectada &copy; 2026 - Ministério da Educação de Angola</p>
      </footer>
    </main>
  </div>
  
  <script src="/js/classes.js"></script>

{% endblock %}