   <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="main-header">
        <div class="header-left">
          <button class="mobile-toggle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
          <h1 class="header-title">Dashboard</h1>
        </div>
        <div class="header-right">
          <div class="header-user">
            <div class="header-user-avatar">AD</div>
            <div class="header-user-info">
              <span class="header-user-name">Administrador</span>
              <span class="header-user-role">Administração</span>
            </div>
          </div>
        </div>
      </header>

      <!-- Page Content -->
      <div class="page-content">
        <!-- Page Header -->
        <div class="page-header">
          <h2 class="page-title">Painel de Controlo</h2>
          <p class="page-subtitle">Visão geral do sistema escolar - Ano Lectivo 2026/2025</p>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            </div>
            <div class="stat-content">
              <div class="stat-value">1.245</div>
              <div class="stat-label">Total de Alunos</div>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon success">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            </div>
            <div class="stat-content">
              <div class="stat-value">48</div>
              <div class="stat-label">Professores</div>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon warning">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
            </div>
            <div class="stat-content">
              <div class="stat-value">36</div>
              <div class="stat-label">Turmas Activas</div>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon info">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 11 18-5v12L3 13v-2z" />
                <path d="M11.6 16.8a3 3 0 1 1-5.8-1.6" />
              </svg>
            </div>
            <div class="stat-content">
              <div class="stat-value">12</div>
              <div class="stat-label">Avisos Activos</div>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <!-- Distribuição por Ciclo -->
          <div class="col-lg-6">
            <div class="card h-100">
              <div class="card-header">
                <h5 class="card-title">Distribuição de Alunos por Ciclo</h5>
              </div>
              <div class="card-body">
                <div class="mb-4">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-secondary">EIA-10AD (7ª - 9ª Classe)</span>
                    <span class="fw-semibold">720 alunos</span>
                  </div>
                  <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-primary" style="width: 58%"></div>
                  </div>
                </div>
                <div class="mb-4">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-secondary">EIA-10AD (10ª - 12ª Classe)</span>
                    <span class="fw-semibold">525 alunos</span>
                  </div>
                  <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-success" style="width: 42%"></div>
                  </div>
                </div>
                <hr>
                <div class="row text-center">
                  <div class="col-4">
                    <div class="fw-bold text-primary">7ª</div>
                    <small class="text-muted">245 alunos</small>
                  </div>
                  <div class="col-4">
                    <div class="fw-bold text-primary">8ª</div>
                    <small class="text-muted">238 alunos</small>
                  </div>
                  <div class="col-4">
                    <div class="fw-bold text-primary">9ª</div>
                    <small class="text-muted">237 alunos</small>
                  </div>
                </div>
                <div class="row text-center mt-3">
                  <div class="col-4">
                    <div class="fw-bold text-success">10ª</div>
                    <small class="text-muted">185 alunos</small>
                  </div>
                  <div class="col-4">
                    <div class="fw-bold text-success">11ª</div>
                    <small class="text-muted">178 alunos</small>
                  </div>
                  <div class="col-4">
                    <div class="fw-bold text-success">12ª</div>
                    <small class="text-muted">162 alunos</small>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Avisos Recentes -->
          <div class="col-lg-6">
            <div class="card h-100">
              <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Avisos Recentes</h5>
                <a href="avisos.html" class="btn btn-sm btn-outline-primary">Ver todos</a>
              </div>
              <div class="card-body p-0">
                <div class="list-group list-group-flush">
                  <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <h6 class="mb-1">Provas Trimestrais</h6>
                        <p class="mb-1 text-muted small">As provas trimestrais do I Trimestre decorrerão de 22 a 26 de
                          Abril de 2026.</p>
                        <span class="badge badge-info">Geral</span>
                      </div>
                      <small class="text-muted">10/04</small>
                    </div>
                  </div>
                  <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <h6 class="mb-1">Entrega das Mini-Pautas</h6>
                        <p class="mb-1 text-muted small">Data limite para entrega das mini-pautas: 30 de Abril de 2026.
                        </p>
                        <span class="badge badge-warning">Professores</span>
                      </div>
                      <small class="text-muted">15/04</small>
                    </div>
                  </div>
                  <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <h6 class="mb-1">Reunião de Encarregados</h6>
                        <p class="mb-1 text-muted small">Reunião geral no dia 10 de Fevereiro às 14h00.</p>
                        <span class="badge badge-primary">Encarregados</span>
                      </div>
                      <small class="text-muted">01/02</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Estatísticas Adicionais -->
        <div class="row g-4 mt-0">
          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h5 class="card-title">Resumo do Ano Lectivo 2026/2025</h5>
              </div>
              <div class="card-body">
                <div class="row g-4">
                  <div class="col-md-3 col-6">
                    <div class="text-center p-3 rounded" style="background: rgba(26, 68, 128, 0.05);">
                      <div class="fw-bold text-primary mb-1" style="font-size: 1.5rem;">95%</div>
                      <div class="text-muted small">Taxa de Assiduidade</div>
                    </div>
                  </div>
                  <div class="col-md-3 col-6">
                    <div class="text-center p-3 rounded" style="background: rgba(22, 163, 74, 0.05);">
                      <div class="fw-bold text-success mb-1" style="font-size: 1.5rem;">87%</div>
                      <div class="text-muted small">Taxa de Aprovação</div>
                    </div>
                  </div>
                  <div class="col-md-3 col-6">
                    <div class="text-center p-3 rounded" style="background: rgba(245, 158, 11, 0.05);">
                      <div class="fw-bold text-warning mb-1" style="font-size: 1.5rem;">14.2</div>
                      <div class="text-muted small">Média Geral</div>
                    </div>
                  </div>
                  <div class="col-md-3 col-6">
                    <div class="text-center p-3 rounded" style="background: rgba(14, 165, 233, 0.05);">
                      <div class="fw-bold text-info mb-1" style="font-size: 1.5rem;">24</div>
                      <div class="text-muted small">Disciplinas Leccionadas</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      {{ include '../components/footer.twig' }}
    </main>
  